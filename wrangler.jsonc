{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "rwjblue-com",
  "compatibility_date": "2026-07-09",
  "workers_dev": false,
  "preview_urls": true,
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "./dist"
  },
  "routes": [
    {
      "pattern": "rwjblue.com",
      "custom_domain": true
    },
    {
      "pattern": "n1rwj.com",
      "custom_domain": true
    }
  ]
}
