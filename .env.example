# Optional Cloudflare deployment values for future local deploy tasks.
# Real values belong in .env locally or GitHub repository secrets in CI.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PROJECT_NAME=rwjblue-com

# Local-only key for Google Maps MCP access.
# Keep the real value in .env and out of git.
GOOGLE_MAPS_API_KEY=
