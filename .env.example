# Optional Cloudflare auth values for local or CI Wrangler deploys.
# Real values belong in .env locally or GitHub repository secrets in CI.
CLOUDFLARE_API_TOKEN=

# Local-only key for Google Maps MCP access.
# Keep the real value in .env and out of git.
GOOGLE_MAPS_API_KEY=

# Local-only token for Fastmail MCP access.
# Keep the real value in .env and out of git.
FASTMAIL_MCP_API_TOKEN=
