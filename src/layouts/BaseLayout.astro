---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Robert Jackson / rwjblue / N1RWJ",
  description = "Robert Jackson, rwjblue, and N1RWJ. Software, open source, amateur radio, notes, and experiments.",
} = Astro.props;

const nav = [
  { href: "/", label: "Home" },
  { href: "/notes/", label: "Notes" },
  { href: "/projects/", label: "Projects" },
  { href: "/radio/", label: "Radio" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="site-name" href="/" aria-label="Robert Jackson home">
          rwjblue / N1RWJ
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          {nav.map((item) => <a href={item.href}>{item.label}</a>)}
          <a href="https://github.com/rwjblue" target="_blank" rel="noreferrer">
            GitHub
          </a>
          <a href="https://www.qrz.com/db/N1RWJ" target="_blank" rel="noreferrer">
            QRZ
          </a>
        </nav>
      </header>

      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
