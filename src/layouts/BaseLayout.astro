---
import "../styles/global.css";

interface Props {
  title?: string;
  socialTitle?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article";
}

const {
  title = "Robert Jackson / rwjblue / N1RWJ",
  socialTitle = title,
  description = "Robert Jackson, rwjblue, and N1RWJ. Software, open source, amateur radio, notes, and experiments.",
  canonicalPath = Astro.url.pathname,
  image,
  imageAlt,
  type = "website",
} = Astro.props;

const absoluteUrl = (path: string) => new URL(path, Astro.url).toString();
const canonicalUrl = absoluteUrl(canonicalPath);
const socialImage = image ? absoluteUrl(image) : undefined;

const nav = [
  { href: "/", label: "Home" },
  { href: "/notes/", label: "Notes" },
  { href: "/projects/", label: "Projects" },
  { href: "/radio/", label: "Radio" },
  { href: "/about/", label: "About" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta id="theme-color" name="theme-color" content="#f7f4ee" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Robert Jackson / Notes"
      href="/rss.xml"
    />
    <meta property="og:site_name" content="Robert Jackson / rwjblue / N1RWJ" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {socialImage && <meta property="og:image" content={socialImage} />}
    {imageAlt && <meta property="og:image:alt" content={imageAlt} />}
    <meta
      name="twitter:card"
      content={socialImage ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}
    {imageAlt && <meta name="twitter:image:alt" content={imageAlt} />}
    <script is:inline>
      (() => {
        const storageKey = "rwjblue-theme";
        const root = document.documentElement;
        const darkQuery = window.matchMedia("(prefers-color-scheme: dark)");
        let savedTheme = null;

        try {
          const storedTheme = window.localStorage.getItem(storageKey);
          if (storedTheme === "light" || storedTheme === "dark") {
            savedTheme = storedTheme;
            root.dataset.theme = storedTheme;
          }
        } catch {
          // A blocked storage API should not prevent system theme detection.
        }

        const resolvedTheme = savedTheme ?? (darkQuery.matches ? "dark" : "light");
        const themeColor = document.querySelector('meta[name="theme-color"]');
        themeColor?.setAttribute(
          "content",
          resolvedTheme === "dark" ? "#111719" : "#f7f4ee",
        );
      })();
    </script>
    <title>{title}</title>
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "22d098b3f6564ca1aba1f6297ab62668"}'
    ></script>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="site-name" href="/" aria-label="Robert Jackson home">
          rwjblue / N1RWJ
        </a>
        <div class="site-header-actions">
          <nav class="site-nav" aria-label="Primary navigation">
            {nav.map((item) => (
              <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
                {item.label}
              </a>
            ))}
            <a href="https://github.com/rwjblue" target="_blank" rel="noreferrer">
              GitHub
            </a>
            <a href="https://www.qrz.com/db/N1RWJ" target="_blank" rel="noreferrer">
              QRZ
            </a>
          </nav>
          <div class="theme-control">
            <button class="theme-toggle" type="button" data-theme-toggle hidden>
              <span aria-hidden="true" class="theme-toggle-icon">
                <svg data-theme-icon="system" viewBox="0 0 24 24">
                  <rect x="3" y="4" width="18" height="14" rx="2"></rect>
                  <path d="M8 22h8M12 18v4"></path>
                </svg>
                <svg data-theme-icon="light" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="4"></circle>
                  <path
                    d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.65 17.65l1.42 1.42M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.65 6.35l1.42-1.42"
                  ></path>
                </svg>
                <svg data-theme-icon="dark" viewBox="0 0 24 24">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                </svg>
              </span>
            </button>
          </div>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <a href="/rss.xml">RSS</a>
        <a href="/about/">About</a>
        <a href="https://bsky.app/profile/rwjblue.com" target="_blank" rel="noreferrer">
          Bluesky
        </a>
        <a href="https://mstdn.social/@rwjblue" target="_blank" rel="me noreferrer">
          Mastodon
        </a>
        <span>N1RWJ · rwjblue</span>
      </footer>
    </div>
    <script>
      const storageKey = "rwjblue-theme";
      const root = document.documentElement;
      const darkQuery = window.matchMedia("(prefers-color-scheme: dark)");
      const toggle = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
      const modes = ["system", "light", "dark"] as const;
      type ThemeMode = (typeof modes)[number];

      const currentMode = (): ThemeMode => {
        const theme = root.dataset.theme;
        return theme === "light" || theme === "dark" ? theme : "system";
      };

      const resolvedMode = (): "light" | "dark" =>
        currentMode() === "system"
          ? darkQuery.matches
            ? "dark"
            : "light"
          : (currentMode() as "light" | "dark");

      const updateThemeUi = () => {
        const mode = currentMode();
        const resolved = resolvedMode();
        const nextMode = modes[(modes.indexOf(mode) + 1) % modes.length];
        const displayMode = mode[0].toUpperCase() + mode.slice(1);
        const displayNext = nextMode[0].toUpperCase() + nextMode.slice(1);
        const status = mode === "system" ? `${displayMode} (${resolved})` : displayMode;

        if (toggle) {
          toggle.hidden = false;
          toggle.dataset.mode = mode;
          toggle.dataset.resolved = resolved;
          toggle.dataset.tooltip = `${status} theme · Next: ${displayNext}`;
          toggle.setAttribute(
            "aria-label",
            `Theme: ${status}. Activate to use ${displayNext} mode.`,
          );
        }

        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute("content", resolved === "dark" ? "#111719" : "#f7f4ee");
      };

      const setTheme = (mode: ThemeMode) => {
        if (mode === "system") {
          delete root.dataset.theme;
        } else {
          root.dataset.theme = mode;
        }

        try {
          if (mode === "system") {
            window.localStorage.removeItem(storageKey);
          } else {
            window.localStorage.setItem(storageKey, mode);
          }
        } catch {
          // The control still works for this page when storage is unavailable.
        }

        updateThemeUi();
        window.dispatchEvent(
          new CustomEvent("themechange", {
            detail: { mode, resolved: resolvedMode() },
          }),
        );
      };

      toggle?.addEventListener("click", () => {
        const mode = currentMode();
        setTheme(modes[(modes.indexOf(mode) + 1) % modes.length]);
      });

      darkQuery.addEventListener("change", () => {
        if (currentMode() === "system") {
          updateThemeUi();
          window.dispatchEvent(
            new CustomEvent("themechange", {
              detail: { mode: "system", resolved: resolvedMode() },
            }),
          );
        }
      });

      updateThemeUi();
    </script>
  </body>
</html>
