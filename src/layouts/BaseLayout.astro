---
import "../styles/global.css";

interface Props {
  title?: string;
  socialTitle?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article";
}

const {
  title = "Robert Jackson / rwjblue / N1RWJ",
  socialTitle = title,
  description = "Robert Jackson, rwjblue, and N1RWJ. Software, open source, amateur radio, notes, and experiments.",
  canonicalPath = Astro.url.pathname,
  image,
  imageAlt,
  type = "website",
} = Astro.props;

const absoluteUrl = (path: string) => new URL(path, Astro.url).toString();
const canonicalUrl = absoluteUrl(canonicalPath);
const socialImage = image ? absoluteUrl(image) : undefined;

const nav = [
  { href: "/", label: "Home" },
  { href: "/notes/", label: "Notes" },
  { href: "/projects/", label: "Projects" },
  { href: "/radio/", label: "Radio" },
  { href: "/about/", label: "About" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Robert Jackson / Notes"
      href="/rss.xml"
    />
    <meta property="og:site_name" content="Robert Jackson / rwjblue / N1RWJ" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {socialImage && <meta property="og:image" content={socialImage} />}
    {imageAlt && <meta property="og:image:alt" content={imageAlt} />}
    <meta
      name="twitter:card"
      content={socialImage ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}
    {imageAlt && <meta name="twitter:image:alt" content={imageAlt} />}
    <title>{title}</title>
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "22d098b3f6564ca1aba1f6297ab62668"}'
    ></script>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="site-name" href="/" aria-label="Robert Jackson home">
          rwjblue / N1RWJ
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          {nav.map((item) => (
            <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          ))}
          <a href="https://github.com/rwjblue" target="_blank" rel="noreferrer">
            GitHub
          </a>
          <a href="https://www.qrz.com/db/N1RWJ" target="_blank" rel="noreferrer">
            QRZ
          </a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <a href="/rss.xml">RSS</a>
        <a href="/about/">About</a>
        <a href="https://bsky.app/profile/rwjblue.com" target="_blank" rel="noreferrer">
          Bluesky
        </a>
        <a href="https://mstdn.social/@rwjblue" target="_blank" rel="me noreferrer">
          Mastodon
        </a>
        <span>N1RWJ · rwjblue</span>
      </footer>
    </div>
  </body>
</html>
