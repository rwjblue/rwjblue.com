---
import "leaflet/dist/leaflet.css";
import { NCDXF_BEACONS } from "../lib/ncdxf-beacons.ts";

const stations = NCDXF_BEACONS.map((beacon, index) => ({
  ...beacon,
  slot: index + 1,
}));
const operationalCount = stations.filter((station) => station.status === "ok").length;
const mapId = "ncdxf-beacon-network-map";
---

<section class="beacon-map-section" aria-labelledby={`${mapId}-title`}>
  <div class="beacon-map-heading">
    <div>
      <p class="section-label">Worldwide network</p>
      <h2 id={`${mapId}-title`}>Eighteen synchronized beacon locations</h2>
      <p>
        The slot number is the transmission order. Select a marker or station
        for its location and Maidenhead grid.
      </p>
    </div>
    <p class="beacon-map-summary">
      {operationalCount} reported operational · {stations.length} scheduled slots
    </p>
  </div>

  <div
    id={mapId}
    class="beacon-network-map beacon-live-map"
    aria-label="World map of NCDXF beacon locations"
  >
  </div>

  <ol class="beacon-station-list" aria-label="NCDXF beacon stations in transmission order">
    {
      stations.map((station) => (
        <li>
          <button type="button" data-beacon-slot={station.slot}>
            <span class="beacon-station-slot">{station.slot}</span>
            <span class="beacon-station-identity">
              <strong>{station.call}</strong>
              <span>{station.entity} · {station.location}</span>
            </span>
            <span class="beacon-station-grid">{station.grid}</span>
            {
              station.status === "off" && (
                <span class="beacon-station-offline">reported off</span>
              )
            }
          </button>
        </li>
      ))
    }
  </ol>
</section>

<script>
  import { createNcdxfBeaconMap } from "../lib/ncdxf-beacon-map";

  const mapElement = document.getElementById("ncdxf-beacon-network-map");
  if (mapElement) {
    const beaconMap = createNcdxfBeaconMap(mapElement, { mode: "network" });

    document.querySelectorAll("[data-beacon-slot]").forEach((button) => {
      button.addEventListener("click", () => {
        const slot = Number(button.getAttribute("data-beacon-slot"));
        if (!Number.isInteger(slot) || slot < 1) return;
        beaconMap.focusBeacon(slot - 1);
        mapElement.scrollIntoView({ behavior: "smooth", block: "center" });
      });
    });
  }
</script>
