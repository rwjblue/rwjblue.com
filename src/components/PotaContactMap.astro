---
import "leaflet/dist/leaflet.css";
import { BAND_COLORS } from "../data/pota/band-colors.mjs";

interface ContactMapPoint {
  lat: number;
  lon: number;
}

interface ContactMapContact {
  timestamp?: string;
  originGrid: string;
  origin: ContactMapPoint;
  destination: ContactMapPoint;
  destinationGrid?: string;
  destinationState?: string;
  destinationCountry?: string;
  band: string;
  source: "grid" | "state" | "country";
}

interface ContactMapDxccEntity {
  dxccCode: string | number;
  name: string;
  flag?: string;
  count: number;
}

interface ContactMapData {
  title: string;
  subtitle: string;
  date: string;
  stationCallsign: string;
  originDxccCode?: string | number;
  dxccEntities?: ContactMapDxccEntity[];
  contacts: ContactMapContact[];
}

function collectBandCounts(contacts: ContactMapContact[]) {
  const bandCounts: Record<string, number> = {};

  for (const contact of contacts) {
    bandCounts[contact.band] = (bandCounts[contact.band] ?? 0) + 1;
  }

  return bandCounts;
}

function dxccCodeForValue(dxcc: string | number | null | undefined) {
  if (dxcc === undefined || dxcc === null || dxcc === "") {
    return undefined;
  }

  const code = Number.parseInt(String(dxcc), 10);
  return Number.isNaN(code) ? String(dxcc) : code;
}

function shouldRenderDxccSummary(map: ContactMapData) {
  if (!map.dxccEntities || map.dxccEntities.length === 0) {
    return false;
  }

  if (map.originDxccCode === undefined || map.originDxccCode === null) {
    return map.dxccEntities.length >= 2;
  }

  const originDxccCode = dxccCodeForValue(map.originDxccCode);
  return map.dxccEntities.some((entity) => {
    return dxccCodeForValue(entity.dxccCode) !== originDxccCode;
  });
}

function formatDxccCount(entity: ContactMapDxccEntity) {
  return entity.count > 1 ? ` (${entity.count})` : "";
}

const { map } = Astro.props as { map: ContactMapData };
const mapId = `pota-contact-map-${map.date ?? "activation"}`;
const dataId = `${mapId}-data`;
const bandColorsId = `${mapId}-band-colors`;
const bandColors = BAND_COLORS;
const bandCounts = collectBandCounts(map.contacts);
---

<section class="contact-map-section" aria-labelledby={`${mapId}-title`}>
  <div class="contact-map-heading">
    <div>
      <p class="section-label">Contact map</p>
      <h2 id={`${mapId}-title`}>{map.title}</h2>
      <p>{map.subtitle}</p>
    </div>
    <p class="contact-map-summary">{map.contacts.length} QSOs</p>
  </div>

  <div id={mapId} class="contact-map" aria-label={`${map.title} contact map`}></div>
  <div class="contact-map-legend" aria-label="Contact map legend">
    {
      Object.entries(bandCounts).map(([band, count]) => (
        <span><i style={`background:${bandColors[band] ?? bandColors.other}`}></i>{band} {count}</span>
      ))
    }
  </div>
  {
    shouldRenderDxccSummary(map) && (
      <div class="contact-map-dxcc" aria-label="DXCC entity summary">
        <span class="contact-map-dxcc-heading">{map.dxccEntities?.length} DXCC Entities</span>
        {
          map.dxccEntities?.map((entity) => (
            <span class="contact-map-dxcc-entity">
              {
                entity.flag && (
                  <span class="contact-map-dxcc-flag" aria-hidden="true">{entity.flag}</span>
                )
              }
              <span>{entity.name}{formatDxccCount(entity)}</span>
            </span>
          ))
        }
      </div>
    )
  }
</section>

<script type="application/json" id={dataId} set:html={JSON.stringify(map)} />
<script type="application/json" id={bandColorsId} set:html={JSON.stringify(bandColors)} />
<script>
  import L from "leaflet";

  const mapElements = document.querySelectorAll(".contact-map");

  for (const mapElement of mapElements) {
    const dataElement = document.getElementById(`${mapElement.id}-data`);
    const bandColorsElement = document.getElementById(`${mapElement.id}-band-colors`);
    if (!dataElement || !bandColorsElement) {
      continue;
    }

    const contactMap = JSON.parse(dataElement.textContent ?? "{}");
    const bandColors = JSON.parse(bandColorsElement.textContent ?? "{}");
    const leafletMap = L.map(mapElement, {
      scrollWheelZoom: false,
    });
    const bounds = L.latLngBounds([]);

    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 18,
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
    }).addTo(leafletMap);

    for (const originPoint of uniqueOrigins(contactMap.contacts)) {
      const latLng = [originPoint.origin.lat, originPoint.origin.lon];

      bounds.extend(latLng);
      L.circleMarker(latLng, {
        radius: 8,
        color: "#fffdfa",
        weight: 3,
        fillColor: "#172026",
        fillOpacity: 1,
      })
        .addTo(leafletMap)
        .bindPopup(`<strong>${escapeHtml(contactMap.stationCallsign)}</strong><span>${escapeHtml(originPoint.originGrid)}</span>`);
    }

    for (const contact of contactMap.contacts) {
      const origin = [contact.origin.lat, contact.origin.lon];
      const latLng = [contact.destination.lat, contact.destination.lon];
      const color = bandColor(contact.band, bandColors);

      bounds.extend(latLng);
      L.polyline([origin, latLng], {
        color,
        opacity: contact.source === "grid" ? 0.22 : 0.32,
        weight: contact.source === "grid" ? 1.3 : 2,
      }).addTo(leafletMap);

      L.circleMarker(latLng, {
        radius: contact.source === "grid" ? 5 : 7,
        color: "#172026",
        weight: contact.source === "grid" ? 1.4 : 2,
        dashArray: contact.source === "grid" ? undefined : "3 2",
        fillColor: color,
        fillOpacity: 0.92,
      })
        .addTo(leafletMap)
        .bindPopup(
          `<strong>${escapeHtml(contact.band)}</strong><span>${escapeHtml(destinationLabel(contact))}</span>`,
        );
    }

    if (bounds.isValid()) {
      leafletMap.fitBounds(bounds, { padding: [24, 24] });
    }
  }

  function bandColor(band, bandColors) {
    return bandColors[String(band).toLowerCase()] ?? bandColors.other;
  }

  function destinationLabel(contact) {
    if (contact.source === "grid") {
      return contact.destinationGrid || "Grid-square position";
    }

    if (contact.source === "state") {
      return contact.destinationState
        ? `Approximate state location (${contact.destinationState})`
        : "Approximate state location";
    }

    return contact.destinationCountry
      ? `Approximate country location (${contact.destinationCountry})`
      : "Approximate country location";
  }

  function uniqueOrigins(contacts) {
    const seen = new Map();

    for (const contact of contacts) {
      const key = `${contact.origin.lat},${contact.origin.lon},${contact.originGrid}`;
      if (!seen.has(key)) {
        seen.set(key, {
          originGrid: contact.originGrid,
          origin: contact.origin,
        });
      }
    }

    return [...seen.values()];
  }

  function escapeHtml(value) {
    return String(value).replace(/[&<>"']/g, (char) => {
      const entities = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };

      return entities[char];
    });
  }
</script>
