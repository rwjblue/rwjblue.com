---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, displayTags } from "../../lib/format";

const notes = (await getCollection("notes")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Notes / Robert Jackson">
  <section class="page-intro">
    <p class="eyebrow">Notes</p>
    <h1>Notes</h1>
    <p>
      Lightweight technical notes, field logs, experiments, and fragments worth
      being able to find again.
    </p>
  </section>

  <ol class="entry-list full">
    {
      notes.map((note) => (
        <li>
          <time datetime={note.data.date.toISOString()}>
            {formatDate(note.data.date)}
          </time>
          <a href={`/notes/${note.id}/`}>{note.data.title}</a>
          <p>{note.data.summary}</p>
          <div class="tags">
            {displayTags(note.data.tags).map((tag) => <span>{tag}</span>)}
          </div>
        </li>
      ))
    }
  </ol>
</BaseLayout>
