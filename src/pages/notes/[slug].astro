---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PotaContactMap from "../../components/PotaContactMap.astro";
import TagHints from "../../components/TagHints.astro";
import { contactMapForNote } from "../../data/pota/contact-maps";
import { formatDate, displayTags } from "../../lib/format";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map((note) => ({ params: { slug: note.id }, props: { note } }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const firstMarkdownImage = note.body.match(
  /!\[([^\]]*)\]\(([^)\s]+)(?:\s+"[^"]*")?\)/,
);
const firstHtmlImage = note.body.match(
  /<img\b[^>]*\bsrc=["']([^"']+)["'][^>]*>/i,
);
const firstHtmlImageAlt = note.body.match(
  /<img\b[^>]*\balt=["']([^"']*)["'][^>]*>/i,
);
const formattedDate = formatDate(note.data.date, "long");
const contactMap = contactMapForNote(note.id);
const shareImage = contactMap
  ? `/images/pota/${note.id}/share.png`
  : firstMarkdownImage?.[2] ?? firstHtmlImage?.[1];
const shareImageAlt = contactMap
  ? `${note.data.title} social share image`
  : firstMarkdownImage?.[1] ?? firstHtmlImageAlt?.[1];
---

<BaseLayout
  title={`${note.data.title} / Notes / Robert Jackson`}
  description={note.data.summary}
  canonicalPath={`/notes/${note.id}/`}
  image={shareImage}
  imageAlt={shareImageAlt}
  type="article"
>
  <article class="document">
    <header>
      <p class="eyebrow">Note</p>
      <h1>{note.data.title}</h1>
      <p class="meta">{formattedDate}</p>
      <p>{note.data.summary}</p>
      <div class="tags">
        {displayTags(note.data.tags).map((tag) => <span>{tag}</span>)}
      </div>
    </header>
    <TagHints tags={note.data.tags} />
    {contactMap && <PotaContactMap map={contactMap} />}
    <Content />
  </article>
</BaseLayout>
