---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GeoJsonBoundaryMap from "../../components/GeoJsonBoundaryMap.astro";
import PotaContactMap from "../../components/PotaContactMap.astro";
import TagHints from "../../components/TagHints.astro";
import { contactMapForNote } from "../../data/pota/contact-maps";
import { formatDate, displayTags } from "../../lib/format";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map((note) => ({ params: { slug: note.id }, props: { note } }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const formattedDate = formatDate(note.data.date, "long");
const contactMap = contactMapForNote(note);
const shouldUseGeneratedShareImage = contactMap || note.data.boundaryMap;
const generatedShareImage = shouldUseGeneratedShareImage
  ? `/images/pota/${note.id}/share.png`
  : `/notes/${note.id}/share.png`;
const shareImage = note.data.shareImage ?? generatedShareImage;
const shareImageAlt = `${note.data.title} social share image`;
---

<BaseLayout
  title={`${note.data.title} / Notes / Robert Jackson`}
  description={note.data.summary}
  canonicalPath={`/notes/${note.id}/`}
  image={shareImage}
  imageAlt={shareImageAlt}
  type="article"
>
  <article class="document">
    <header>
      <p class="eyebrow">Note</p>
      <h1>{note.data.title}</h1>
      <p class="meta">{formattedDate}</p>
      <p>{note.data.summary}</p>
      <div class="tags">
        {displayTags(note.data.tags).map((tag) => <span>{tag}</span>)}
      </div>
    </header>
    <TagHints tags={note.data.tags} />
    {contactMap && <PotaContactMap map={contactMap} />}
    {note.data.boundaryMap && <GeoJsonBoundaryMap map={note.data.boundaryMap} />}
    <Content />
  </article>
</BaseLayout>
