---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const notes = (await getCollection("notes"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = await getCollection("projects");

const bench = [
  {
    label: "Software",
    text: "Rust tooling, TypeScript infrastructure, CI/build systems, open source maintenance.",
  },
  {
    label: "Radio",
    text: "N1RWJ, CW practice, POTA, portable station setup, remote operation.",
  },
  {
    label: "Publishing",
    text: "Notes, field logs, experiments, and small tools.",
  },
];

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---

<BaseLayout>
  <section class="hero compact" aria-labelledby="page-title">
    <div class="intro">
      <p class="eyebrow">Robert Jackson / rwjblue / N1RWJ</p>
      <h1 id="page-title">Robert Jackson</h1>
      <p class="lede strong">
        I build and maintain developer tools, infrastructure, and open source software.
      </p>
      <p class="lede">
        These days that mostly means Rust, TypeScript, Go, Python, build systems,
        test infrastructure, and the parts of engineering workflows that need to
        keep working for years.
      </p>
      <p class="lede">
        I also operate amateur radio as N1RWJ, with interests around CW, POTA,
        portable HF, remote stations, and RF experimentation.
      </p>
    </div>

    <aside class="bench-panel" aria-labelledby="bench-title">
      <h2 id="bench-title">Current bench</h2>
      <div class="bench-list">
        {
          bench.map((item) => (
            <div>
              <span>{item.label}</span>
              <p>{item.text}</p>
            </div>
          ))
        }
      </div>
    </aside>
  </section>

  <section class="section-grid" aria-label="Recent activity and selected artifacts">
    <div class="section-block">
      <div class="section-heading">
        <p class="section-label">Recent</p>
        <h2>Recent from the bench</h2>
      </div>
      <ol class="entry-list">
        {
          notes.map((note) => (
            <li>
              <time datetime={note.data.date.toISOString()}>
                {formatDate(note.data.date)}
              </time>
              <a href={`/notes/${note.id}/`}>{note.data.title}</a>
              <p>{note.data.summary}</p>
            </li>
          ))
        }
      </ol>
    </div>

    <div class="section-block">
      <div class="section-heading">
        <p class="section-label">Artifacts</p>
        <h2>Selected artifacts</h2>
      </div>
      <div class="artifact-list">
        {
          projects.map((project) => (
            <a href={`/projects/${project.id}/`} class="artifact-item">
              <span>{project.data.status}</span>
              <strong>{project.data.title}</strong>
              <p>{project.data.summary}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bridge" aria-labelledby="bridge-title">
    <p class="section-label">Workshop</p>
    <h2 id="bridge-title">Software and radio share the same habits.</h2>
    <p>
      Tooling, infrastructure, portable radio, and RF experiments all reward the
      same kind of work: clear logs, repeatable setups, careful debugging, and
      honest notes about what failed.
    </p>
    <nav class="path-links" aria-label="Workshop paths">
      <a href="/notes/">Notes</a>
      <a href="/projects/">Projects</a>
      <a href="/radio/">Radio</a>
      <a href="/now/">Now</a>
    </nav>
  </section>
</BaseLayout>
