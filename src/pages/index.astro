---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate } from "../lib/format";

const notes = (await getCollection("notes"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.updated.valueOf() - a.data.updated.valueOf(),
);

const recentProjects = projects.slice(0, 3);

const currentBench = [
  {
    label: "Radio",
    text: "N1RWJ, CW practice, POTA, portable station setup, remote operation.",
  },
  {
    label: "Software",
    text: "Rust tooling, TypeScript infrastructure, CI/build systems, open source maintenance.",
  },
  {
    label: "Publishing",
    text: "Notes, field logs, experiments, and small tools.",
  },
];

---

<BaseLayout>
  <section class="hero compact" aria-labelledby="page-title">
    <div class="intro">
      <h1 id="page-title">Robert Jackson</h1>
      <p class="lede strong">
        I operate amateur radio as N1RWJ, with a focus on portable HF, CW, and practical station work.
      </p>
      <p class="lede">
        Radio is where I spend a lot of my workshop time: POTA, portable station
        setup, remote operation, antennas, logging, and RF experimentation.
      </p>
      <p class="lede">
        I also build and maintain software, mostly Rust, TypeScript, Go, Python,
        build systems, test infrastructure, and open source tools that need to
        keep working for years.
      </p>
    </div>

    <aside class="bench-panel" aria-labelledby="bench-title">
      <h2 id="bench-title">Current bench</h2>
      <div class="bench-list">
        {
          currentBench.map((item) => (
            <div>
              <span>{item.label}</span>
              <p>{item.text}</p>
            </div>
          ))
        }
      </div>
    </aside>
  </section>

  <section class="section-grid" aria-label="Recent activity and recently updated projects">
    <div class="section-block">
      <div class="section-heading">
        <p class="section-label">Recent</p>
        <h2>Recent from the bench</h2>
      </div>
      <ol class="entry-list">
        {
          notes.map((note) => (
            <li>
              <time datetime={note.data.date.toISOString()}>
                {formatDate(note.data.date)}
              </time>
              <a href={`/notes/${note.id}/`}>{note.data.title}</a>
              <p>{note.data.summary}</p>
            </li>
          ))
        }
      </ol>
      <nav class="section-more" aria-label="All notes">
        <a href="/notes/">All notes →</a>
      </nav>
    </div>

    <div class="section-block">
      <div class="section-heading">
        <p class="section-label">Projects</p>
        <h2>Recently updated projects</h2>
      </div>
      <div class="artifact-list">
        {
          recentProjects.map((project) => (
            <a href={`/projects/${project.id}/`} class="artifact-item">
              <span>
                {project.data.status} · updated {formatDate(project.data.updated)}
              </span>
              <strong>{project.data.title}</strong>
              <p>{project.data.summary}</p>
            </a>
          ))
        }
      </div>
      <nav class="section-more" aria-label="All projects">
        <a href="/projects/">All projects →</a>
      </nav>
    </div>
  </section>

  <section class="bridge" aria-labelledby="bridge-title">
    <p class="section-label">Workshop</p>
    <h2 id="bridge-title">Software and radio share the same habits.</h2>
    <p>
      Tooling, infrastructure, portable radio, and RF experiments all reward the
      same kind of work: clear logs, repeatable setups, careful debugging, and
      honest notes about what failed.
    </p>
    <nav class="path-links" aria-label="Workshop paths">
      <a href="/notes/">Notes</a>
      <a href="/projects/">Projects</a>
      <a href="/radio/">Radio</a>
    </nav>
  </section>
</BaseLayout>
