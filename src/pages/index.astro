---
import "../styles/global.css";

const links = [
  { href: "https://github.com/rwjblue", label: "GitHub" },
  { href: "https://www.qrz.com/db/N1RWJ", label: "N1RWJ" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Robert Jackson, rwjblue, and N1RWJ. Software, open source, amateur radio, and notes."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Robert Jackson / rwjblue / N1RWJ</title>
  </head>
  <body>
    <main class="shell">
      <section class="hero" aria-labelledby="page-title">
        <div class="intro">
          <p class="eyebrow">Robert Jackson / rwjblue / N1RWJ</p>
          <h1 id="page-title">Robert Jackson</h1>
          <p class="tagline">Software, open source, and amateur radio.</p>
          <p class="lede">
            I work on developer tools and open source as rwjblue. N1RWJ is my
            amateur radio callsign. This is the front door for the public parts of
            both.
          </p>
          <nav class="links" aria-label="Profile links">
            {
              links.map((link) => (
                <a href={link.href} target="_blank" rel="noreferrer">
                  {link.label}
                </a>
              ))
            }
          </nav>
        </div>

        <aside class="identity-card" aria-label="Identity summary">
          <div class="card-top">
            <div class="mark" aria-hidden="true">RJ</div>
            <div>
              <strong>rwjblue</strong>
              <span>Robert Jackson online</span>
            </div>
          </div>
          <div class="identity-list">
            <div>
              <span>Software</span>
              <strong>Developer tooling, open source, and long-running projects.</strong>
            </div>
            <div>
              <span>Radio</span>
              <strong>N1RWJ on the amateur bands.</strong>
            </div>
            <div>
              <span>Notes</span>
              <strong>Occasional public writing will live here.</strong>
            </div>
          </div>
        </aside>
      </section>

      <section class="areas" aria-label="Areas">
        <article>
          <p class="section-label">Software</p>
          <h2>Open source and engineering</h2>
          <p>
            I work on software, developer tooling, and open source projects as
            rwjblue.
          </p>
        </article>

        <article>
          <p class="section-label">Radio</p>
          <h2>N1RWJ</h2>
          <p>
            N1RWJ is my amateur radio callsign. More radio-specific notes may live
            here later.
          </p>
        </article>
      </section>
    </main>
  </body>
</html>
