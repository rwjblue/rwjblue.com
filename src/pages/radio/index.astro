---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const radioNotes = (await getCollection("notes"))
  .filter((note) => note.data.tags.includes("radio"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  });
---

<BaseLayout title="Radio / N1RWJ">
  <section class="page-intro">
    <p class="eyebrow">Radio</p>
    <h1>N1RWJ</h1>
    <p>
      I operate amateur radio as N1RWJ. My radio interests are mostly technical
      and practical: portable HF, CW, POTA, station design, remote operation,
      antennas, logging, and field workflows.
    </p>
  </section>

  <section class="section-block wide">
    <div class="section-heading">
      <p class="section-label">Radio work</p>
      <h2>What belongs here</h2>
    </div>
    <div class="split-list">
      <div>
        <h3>Field notes</h3>
        <p>POTA activations, portable station setup, operating constraints, and cleanup notes.</p>
      </div>
      <div>
        <h3>Station work</h3>
        <p>Remote operation, antennas, RF debugging, logging, and equipment choices.</p>
      </div>
      <div>
        <h3>Practice</h3>
        <p>CW practice, repeatable workflows, and the small adjustments that make operating smoother.</p>
      </div>
    </div>
  </section>

  <section class="section-block wide">
    <div class="section-heading">
      <p class="section-label">Field reports</p>
      <h2>Radio notes</h2>
    </div>
    <ol class="entry-list full">
      {
        radioNotes.map((note) => (
          <li>
            <time datetime={note.data.date.toISOString()}>
              {formatDate(note.data.date)}
            </time>
            <a href={`/notes/${note.id}/`}>{note.data.title}</a>
            <p>{note.data.summary}</p>
            <div class="tags">
              {note.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="bridge" aria-labelledby="pota-project-title">
    <p class="section-label">POTA</p>
    <h2 id="pota-project-title">2026 Activate All RI POTA</h2>
    <p>
      I am tracking the project to activate every POTA reference associated with
      Rhode Island by the end of 2026.
    </p>
    <nav class="path-links" aria-label="POTA project">
      <a href="/projects/2026-activate-all-ri-pota/">View the tracker</a>
    </nav>
  </section>
</BaseLayout>
