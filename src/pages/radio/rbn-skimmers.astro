---
import "leaflet/dist/leaflet.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="RBN Skimmer Finder / N1RWJ"
  description="Find nearby active Reverse Beacon Network skimmers from your current location or Maidenhead grid, then open RBN with spot filters prefilled."
  canonicalPath="/radio/rbn-skimmers/"
>
  <section class="rbn-utility-intro">
    <div class="rbn-utility-copy">
      <p class="eyebrow">Operating tool</p>
      <h1>RBN Skimmer Finder</h1>
      <p class="lede">
        Rank active Reverse Beacon Network receivers by distance from your
        operating position, then open a focused RBN spot feed.
      </p>
    </div>
    <aside class="rbn-signal-note" aria-labelledby="rbn-signal-note-title">
      <p class="section-label">Range, not a forecast</p>
      <h2 id="rbn-signal-note-title">Start with the nearest ears.</h2>
      <p>
        Distance is a useful first filter. What a skimmer hears still depends
        on the band, path, antenna, and local noise.
      </p>
    </aside>
  </section>

  <section class="section-block wide rbn-skimmer-tool" id="rbn-skimmer-tool">
    <div class="rbn-setup">
      <div class="rbn-setup-heading">
        <p class="section-label">Operating position</p>
        <h2>Set your location.</h2>
        <p>
          Browser coordinates stay on this device. The six-character grid is
          added to the URL so the result can be shared.
        </p>
      </div>
      <div class="rbn-setup-controls">
        <div class="rbn-location-row">
          <button id="rbn-use-location" class="rbn-primary" type="button">
            Use browser location
          </button>
          <label class="rbn-grid-field" for="rbn-grid">
            <span>Grid</span>
            <input
              id="rbn-grid"
              type="text"
              inputmode="text"
              autocomplete="off"
              placeholder="EL96WD"
            />
          </label>
          <button id="rbn-apply-grid" class="rbn-secondary" type="button">
            Apply grid
          </button>
        </div>
        <div class="rbn-status-line">
          <span>Live RBN status</span>
          <p id="rbn-status" aria-live="polite">Waiting for a location.</p>
        </div>
      </div>
    </div>

    <div class="rbn-results-layout">
      <div class="rbn-results-panel">
        <div class="rbn-results-heading">
          <div>
            <p class="section-label">Nearest active skimmers</p>
            <h2>Ranked receivers</h2>
            <p class="rbn-results-help">
              Sorted by distance, with the closest two selected to start.
            </p>
          </div>
          <p id="rbn-count" class="rbn-count"></p>
        </div>
        <div id="rbn-results" class="rbn-results" aria-live="polite">
          <p class="rbn-empty">Enter a grid or use browser location to rank active skimmers.</p>
        </div>
      </div>

      <div class="rbn-map-panel">
        <p class="section-label">Map</p>
        <h2>Receiver locations</h2>
        <p class="rbn-map-help">Selected skimmers use the darker markers.</p>
        <div id="rbn-map" class="rbn-map" aria-label="Nearest RBN skimmers map"></div>
      </div>
    </div>

    <div class="rbn-handoff">
      <div>
        <p class="section-label">RBN handoff</p>
        <h2>Open a focused spot feed.</h2>
        <p>
          Checked skimmers become the spotter filter. Target calls are optional
          and can include wildcards.
        </p>
      </div>
      <label class="rbn-target-field" for="rbn-targets">
        <span>Target calls</span>
        <input
          id="rbn-targets"
          type="text"
          autocomplete="off"
          placeholder="K2A,K2B,K2C or K2*"
        />
      </label>
      <a id="rbn-open-link" class="rbn-open-link" href="https://www.reversebeacon.net/main.php">
        Open on RBN
      </a>
      <p id="rbn-link-summary" class="rbn-link-summary">
        Select skimmers to build an RBN link.
      </p>
    </div>

    <nav class="path-links" aria-label="Radio utility navigation">
      <a href="/radio/">Back to radio</a>
      <a href="https://www.reversebeacon.net/nodes/detail.php" target="_blank" rel="noreferrer">
        RBN active nodes
      </a>
      <a href="https://www.reversebeacon.net/main.php" target="_blank" rel="noreferrer">
        RBN spots
      </a>
    </nav>
  </section>
</BaseLayout>

<script>
  import { initRbnSkimmerTool } from "../../lib/rbn-skimmers-client";

  initRbnSkimmerTool();
</script>
