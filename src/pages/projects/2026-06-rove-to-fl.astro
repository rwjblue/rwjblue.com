---
import "leaflet/dist/leaflet.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import itinerary from "../../../data/pota/rove-to-fl/itinerary.json";

interface OvernightStrategy {
  goal: string;
  recommendedPattern: string[];
  summary: string;
  fallbackNote?: string;
}
interface RestOfTripDraft {
  status: string;
  assumptions: string[];
  overnightStrategy?: OvernightStrategy;
  risk?: string;
}
interface MapOverlayPoint {
  id?: string;
  label?: string;
  reference?: string;
  name?: string;
  state?: string;
  type?: string;
  status?: string;
  priority?: string;
  goal?: string;
  role?: string;
  latitude: number;
  longitude: number;
  notes?: string;
}
interface MapOverlays {
  anchors: MapOverlayPoint[];
  parkPoints: MapOverlayPoint[];
}
interface OverviewStop {
  date: string;
  destination: string;
  type: string;
  driveFromPrior?: string;
  expectedStay: string;
  references?: string[];
  detailUrl?: string;
  status?: "set" | "placeholder";
  notes: string;
}
interface FieldNote {
  date: string;
  title: string;
  href: string;
  summary: string;
}
interface NavigationCoordinate {
  label: string;
  context: string;
  latitude: number;
  longitude: number;
  reference?: string;
  address?: string;
  notes: string;
}

const mapOverlays =
  typeof (itinerary as { mapOverlays?: unknown }).mapOverlays === "object" &&
  (itinerary as { mapOverlays?: unknown }).mapOverlays
    ? ((itinerary as { mapOverlays: MapOverlays }).mapOverlays)
    : { anchors: [], parkPoints: [] };
const mapOverlaysJson = JSON.stringify(mapOverlays);

const tripConstraints = itinerary.constraints as Record<string, unknown>;
const departureWindow = Array.isArray(tripConstraints.departureWindow)
  ? (tripConstraints.departureWindow as string[])
  : [];
const requiredJurisdictions = Array.isArray(tripConstraints.requiredJurisdictions)
  ? (tripConstraints.requiredJurisdictions as string[])
  : [];
const dcActivation =
  typeof tripConstraints.dcActivation === "object" && tripConstraints.dcActivation
    ? (tripConstraints.dcActivation as { timing?: string; notes?: string })
    : null;
const vehicle =
  typeof tripConstraints.vehicle === "object" && tripConstraints.vehicle
    ? (tripConstraints.vehicle as {
        type?: string;
        preferredChargingNetwork?: string;
        chargingStopMinutes?: number;
        drivingHoursBetweenChargingStops?: number;
      })
    : null;
const weekendPlanning =
  typeof tripConstraints.weekendPlanning === "object" && tripConstraints.weekendPlanning
    ? (tripConstraints.weekendPlanning as {
        notes?: string;
        candidateHighRoveDay?: { parkCount?: number; status?: string };
      })
    : null;
const roveCounting =
  typeof tripConstraints.roveCounting === "object" && tripConstraints.roveCounting
    ? (tripConstraints.roveCounting as {
        unit?: string;
        dayBoundary?: string;
        multiParkRule?: string;
        eveningStrategy?: string;
      })
    : null;
const workingDeparture =
  typeof tripConstraints.workingDeparture === "object" && tripConstraints.workingDeparture
    ? (tripConstraints.workingDeparture as {
        date?: string;
        localWindow?: string;
        status?: string;
        notes?: string;
      })
    : null;
const riActivation =
  typeof tripConstraints.riActivation === "object" && tripConstraints.riActivation
    ? (tripConstraints.riActivation as {
        preferredTiming?: string;
        fallbackTiming?: string;
        status?: string;
        notes?: string;
      })
    : null;

function formatShortDate(iso: string) {
  return new Date(`${iso}T12:00:00Z`).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}

const departureLabel =
  departureWindow.length === 2
    ? `${formatShortDate(departureWindow[0])}-${formatShortDate(departureWindow[1])}`
    : departureWindow.map(formatShortDate).join(", ");
const workingDepartureLabel = workingDeparture?.date
  ? `${formatShortDate(workingDeparture.date)} ${workingDeparture.localWindow ?? ""}`.trim()
  : null;
const planningConclusions = Array.isArray(
  (itinerary as { planningConclusions?: unknown }).planningConclusions
)
  ? ((itinerary as { planningConclusions: string[] }).planningConclusions)
  : [];
const restOfTripDraft =
  typeof (itinerary as { restOfTripDraft?: unknown }).restOfTripDraft === "object" &&
  (itinerary as { restOfTripDraft?: unknown }).restOfTripDraft
    ? ((itinerary as { restOfTripDraft: RestOfTripDraft }).restOfTripDraft)
    : null;
const overnightStrategy = restOfTripDraft?.overnightStrategy ?? null;
const parkStopPlanning =
  typeof tripConstraints.parkStopPlanning === "object" && tripConstraints.parkStopPlanning
    ? (tripConstraints.parkStopPlanning as {
        offHighwayStopHours?: number;
        meaning?: string;
        overnightParkException?: string;
      })
    : null;
const overviewStops: OverviewStop[] = [
  {
    date: "2026-06-19",
    destination: "Hope, RI",
    type: "Start",
    expectedStay: "Depart Friday morning",
    notes: "Home base before the RI activation and southbound work-positioning day.",
  },
  {
    date: "2026-06-19",
    destination: "Rockville Wildlife Management Area, RI",
    type: "POTA",
    driveFromPrior: "45m / 37.5 mi from Hope",
    expectedStay: "~1h activation",
    references: ["US-6991"],
    notes: "Unactivated Rhode Island reference that fits the I-95 southbound route better than JL Curran.",
  },
  {
    date: "2026-06-19",
    destination: "Silver Sands State Park, CT",
    type: "POTA",
    driveFromPrior: "1h 29m / 86.2 mi from Rockville",
    expectedStay: "~1h activation",
    references: ["US-1716"],
    notes: "Friday morning Connecticut activation before the lower-Hudson work position.",
  },
  {
    date: "2026-06-19",
    destination: "Stamford / White Plains work position",
    type: "Work block",
    driveFromPrior: "35m / 29.8 mi from Silver Sands",
    expectedStay: "13:00-17:00 work window",
    notes: "Position near the NY activation while avoiding the thickest NYC-area traffic.",
  },
  {
    date: "2026-06-19",
    destination: "Tallman Mountain State Park, NY",
    type: "POTA",
    driveFromPrior: "33m / 29.5 mi from Stamford",
    expectedStay: "~1h activation",
    references: ["US-2149"],
    notes: "New York activation after work; start promptly because the park is dawn-to-dusk.",
  },
  {
    date: "2026-06-19",
    destination: "Edison, NJ hotel",
    type: "Hotel",
    driveFromPrior: "1h 06m / 53.9 mi from Tallman",
    expectedStay: "Friday overnight",
    notes: "Booked Friday anchor close to Cheesequake, with good Tesla Supercharger coverage nearby.",
  },
  {
    date: "2026-06-20",
    destination: "Cheesequake State Park, NJ",
    type: "POTA",
    driveFromPrior: "21m / 15.0 mi from Edison",
    expectedStay: "~1h activation",
    references: ["US-1611"],
    notes: "Saturday morning NJ activation; local advice says any available lot works, but avoid playground, lake, and BBQ areas if crowded.",
  },
  {
    date: "2026-06-20",
    destination: "John Heinz National Wildlife Refuge, PA",
    type: "POTA",
    driveFromPrior: "1h 24m / 88.2 mi from Cheesequake",
    expectedStay: "~1h activation",
    references: ["US-0512"],
    notes: "Selected PA branch; use the Lindbergh Boulevard entrance and main parking/pavilion area. Trails are sunrise-to-sundown.",
  },
  {
    date: "2026-06-20",
    destination: "Fox Point State Park, DE",
    type: "POTA",
    driveFromPrior: "25m / 20.9 mi from John Heinz",
    expectedStay: "~1h activation",
    references: ["US-1738", "US-9878"],
    notes: "Delaware activation; local advice points to the northeast corner of the first/main lot for the Northern Delaware Greenway 2-fer.",
  },
  {
    date: "2026-06-20",
    destination: "C&O Canal / Anglers, MD",
    type: "POTA",
    driveFromPrior: "late route adjustment from Bear, DE",
    expectedStay: "Activate after 20:00 for Sunday UTC",
    references: ["US-0015"],
    notes: "Selected late-arrival Maryland all-states anchor; lower count than Greenbelt but cleaner without a Greenbelt campsite.",
  },
  {
    date: "2026-06-20",
    destination: "Foggy Bottom, DC hotel",
    type: "Hotel",
    driveFromPrior: "position after C&O / optional LBJ",
    expectedStay: "Saturday overnight",
    notes: "Fixed DC anchor for the Sunday rove.",
  },
  {
    date: "2026-06-21",
    destination: "DC / NoVA rove sequence",
    type: "Detailed rove",
    driveFromPrior: "Starts from Foggy Bottom",
    expectedStay: "Cheetah baseline; VA missed, now Monday fallback",
    detailUrl: "/projects/2026-06-rove-to-fl/sunday/",
    notes: "Detailed stop order lives on the Sunday rove page; Meadowood and Mason Neck were the planned VA finishes, but VA now moves to Petersburg Monday morning.",
  },
  {
    date: "2026-06-21",
    destination: "Fredericksburg, VA hotel",
    type: "Hotel",
    driveFromPrior: "after DC / NoVA rove",
    expectedStay: "Sunday overnight",
    notes: "Booked anchor before the Monday VA/NC southbound leg.",
  },
  {
    date: "2026-06-22",
    destination: "Petersburg National Battlefield, VA",
    type: "POTA",
    driveFromPrior: "1h 21m / 85.6 mi from Fredericksburg",
    expectedStay: "~1h quick morning activation",
    references: ["US-0707"],
    notes: "Selected Virginia activation on the way to Medoc Mountain; use the Eastern Front visitor-center area for a low-friction stop.",
  },
  {
    date: "2026-06-22",
    destination: "Medoc Mountain State Park, NC",
    type: "POTA",
    driveFromPrior: "1h 23m / 87.1 mi from Petersburg",
    expectedStay: "~1h activation",
    references: ["US-2744"],
    notes: "Selected North Carolina activation after banking VA at Petersburg.",
  },
  {
    date: "2026-06-22",
    destination: "Florence, SC hotel",
    type: "Hotel",
    driveFromPrior: "3h 09m / 199.4 mi from Medoc Mountain",
    expectedStay: "Monday overnight",
    notes: "Booked Monday anchor after the Medoc Mountain activation.",
  },
  {
    date: "2026-06-23",
    destination: "Woods Bay State Park, SC",
    type: "POTA backup",
    driveFromPrior: "33m / 27.7 mi from Florence",
    expectedStay: "~1h activation if used",
    references: ["US-2915"],
    notes: "Early South Carolina backup/add-on before relying on Savannah NWR near the Georgia border.",
  },
  {
    date: "2026-06-23",
    destination: "Savannah National Wildlife Refuge",
    type: "POTA",
    driveFromPrior: "2h 13m / 152.2 mi from Woods Bay if used",
    expectedStay: "~1h activation",
    references: ["US-0522"],
    notes: "Use Abercorn Landing for the low-friction stop: a boat-ramp lot just inside the refuge boundary with a picnic table and no facilities. No wires or ropes in trees, and no ground stakes in the refuge.",
  },
  {
    date: "2026-06-23",
    destination: "Jekyll Island, GA hotel / Jekyll Island State Park",
    type: "Hotel + POTA",
    driveFromPrior: "1h 31m / 94.9 mi from Savannah NWR",
    expectedStay: "Tuesday overnight; activate on island",
    references: ["US-0636"],
    notes: "Booked Tuesday anchor; the island is the Georgia POTA park, so this covers GA without a separate morning detour.",
  },
  {
    date: "2026-06-24",
    destination: "Ocala, FL",
    type: "Family anchor",
    driveFromPrior: "2h 58m / 173.3 mi from Jekyll Island",
    expectedStay: "Wednesday/Thursday nights",
    notes: "Family positioning before local Florida activations and Field Day arrival.",
  },
  {
    date: "2026-06-25",
    destination: "Ross Prairie State Forest / Marjorie Harris Carr Cross State Park, FL",
    type: "POTA",
    driveFromPrior: "10-15m from the Ocala family base",
    expectedStay: "Morning hike-in activation before work",
    references: ["US-4638", "US-3637"],
    notes: "Actual Thursday Florida stop was a Ross Prairie hike-in twofer with Marjorie Harris Carr Cross State Park.",
  },
  {
    date: "2026-06-26",
    destination: "John D. MacArthur Beach State Park, FL",
    type: "POTA",
    driveFromPrior: "3h 56m / 232.1 mi from Ocala",
    expectedStay: "Friday evening activation",
    references: ["US-1884"],
    notes: "Final target activation near Singer Island.",
  },
  {
    date: "2026-06-26",
    destination: "Singer Island / Riviera Beach, FL",
    type: "Destination",
    driveFromPrior: "9m / 3.7 mi from John D. MacArthur",
    expectedStay: "Field Day weekend",
    notes: "Arrival target for the June 27-28 Field Day weekend.",
  },
];

const fieldNotes: FieldNote[] = [
  {
    date: "2026-06-19",
    title: "Rhode Island-to-Florida rove, day one",
    href: "/notes/2026-06-19-rhode-island-to-florida-rove-day-one/",
    summary:
      "Rockville, Silver Sands, and Tallman Mountain opened the southbound rove with 56 QSOs.",
  },
  {
    date: "2026-06-20",
    title: "Rhode Island-to-Florida rove, day two",
    href: "/notes/2026-06-20-rhode-island-to-florida-rove-day-two/",
    summary:
      "New Jersey, Pennsylvania, Delaware, and the DC-area late stop added 51 QSOs.",
  },
  {
    date: "2026-06-21",
    title: "Washington DC POTA rove",
    href: "/notes/2026-06-21-washington-dc-pota-rove/",
    summary:
      "A walking-and-driving DC route produced 106 Sunday-route QSOs and cleared the Cheetah threshold.",
  },
  {
    date: "2026-06-22",
    title: "Rhode Island-to-Florida rove, day four",
    href: "/notes/2026-06-22-rhode-island-to-florida-rove-day-four/",
    summary:
      "Fredericksburg and Medoc Mountain moved the rove from Virginia toward South Carolina with 23 CW QSOs.",
  },
  {
    date: "2026-06-23",
    title: "Rhode Island-to-Florida rove, day five",
    href: "/notes/2026-06-23-rhode-island-to-florida-rove-day-five/",
    summary:
      "Woods Bay, Savannah NWR, and Jekyll Island added South Carolina and Georgia with 46 CW QSOs.",
  },
  {
    date: "2026-06-25",
    title: "Ross Prairie morning twofer",
    href: "/notes/2026-06-25-ross-prairie-twofer-pota/",
    summary:
      "A Florida hike-in twofer at Ross Prairie produced 13 CW QSOs before work.",
  },
];

const navigationCoordinates: NavigationCoordinate[] = [
  {
    label: "Woods Bay State Park",
    context: "Tuesday optional SC backup/add-on",
    reference: "US-2915",
    latitude: 33.9494394,
    longitude: -79.9762942,
    address: "11020 Woods Bay Rd, Olanta, SC 29114",
    notes: "Use if the day has enough slack before Savannah NWR.",
  },
  {
    label: "Abercorn Landing",
    context: "Savannah NWR operating spot",
    reference: "US-0522",
    latitude: 32.2586944,
    longitude: -81.1784167,
    address: "112 Abercorn Landing Rd, Rincon, GA 31326",
    notes:
      "Recommended by Bill W4ZDP and Stacy WA4IDS as the simple quiet activation spot just inside the refuge boundary.",
  },
  {
    label: "Courtyard by Marriott Jekyll Island",
    context: "Tuesday hotel / Jekyll Island State Park anchor",
    reference: "US-0636",
    latitude: 31.0374673,
    longitude: -81.4141493,
    address: "178 S Beachview Dr, Jekyll Island, GA 31527",
    notes: "Booked overnight; the whole island counts as Jekyll Island State Park.",
  },
];

function potaUrl(reference: string) {
  return `https://pota.app/#/park/${reference}`;
}

function formatCoordinate(value: number) {
  return value.toFixed(7);
}

function coordinatePair(point: NavigationCoordinate) {
  return `${formatCoordinate(point.latitude)}, ${formatCoordinate(point.longitude)}`;
}

function googleMapsUrl(point: NavigationCoordinate) {
  return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
    `${point.latitude},${point.longitude}`
  )}`;
}
---

<BaseLayout
  title="2026 Rove to FL / N1RWJ"
  description="A week-long POTA activation drive from Rhode Island down the I-95 corridor to Singer Island, FL for Field Day 2026."
  canonicalPath="/projects/2026-06-rove-to-fl/"
>
  <section class="pota-tracker-hero" aria-labelledby="page-title">
    <div>
      <p class="eyebrow">Project / POTA</p>
      <h1 id="page-title">2026 Rove to FL</h1>
      <p class="lede strong">
        I-95 corridor from Rhode Island to Singer Island, FL — activating parks
        along the way and arriving June 26 for Field Day 2026.
      </p>
      <p class="lede">
        Fixed hotel anchors and selected POTA targets are now set through
        Florida. Petersburg National Battlefield now covers VA, Medoc Mountain
        covers NC, and Woods Bay is the early SC backup/add-on.
      </p>
    </div>

    <div class="pota-tracker-panel">
      <aside class="pota-scoreboard" aria-label="Trip details">
        <div>
          <strong>Jun 26</strong>
          <span>arrive FL</span>
        </div>
        <div>
          <strong>Jun 27–28</strong>
          <span>Field Day</span>
        </div>
        <div>
          <strong>{mapOverlays.parkPoints.length}</strong>
          <span>target parks</span>
        </div>
        <p>Singer Island / Riviera Beach, FL</p>
      </aside>

      <nav class="rove-subnav" aria-label="Rove planning pages">
        <a href="/projects/2026-06-rove-to-fl/">Overview</a>
        <a href="/projects/2026-06-rove-to-fl/saturday/">Saturday rove</a>
        <a href="/projects/2026-06-rove-to-fl/sunday/">Sunday DC rove</a>
      </nav>

      <section class="pota-map-section" aria-labelledby="map-title">
        <div class="section-heading">
          <p class="section-label">Map</p>
          <h2 id="map-title">Trip anchors and targets</h2>
        </div>
        <div id="rove-map" class="pota-map" aria-label="Map of trip hotel anchors and selected POTA targets"></div>
        <div class="pota-map-legend rove-map-legend" aria-label="Map marker legend">
          <span><i style="background:#1f6feb;border-color:#172026"></i>Hotels / anchors</span>
          <span><i style="background:#167246;border-color:#172026"></i>Target parks</span>
          <span><i style="background:#f28e2b;border-color:#172026"></i>Alternate park</span>
        </div>
      </section>
    </div>
  </section>

  <section class="section-block wide" aria-labelledby="planning-title">
    <div class="section-heading">
      <h2 id="planning-title">Planning constraints</h2>
    </div>

    <dl class="rove-constraint-grid">
      {workingDepartureLabel ? (
        <div>
          <dt>Departure</dt>
          <dd>{workingDepartureLabel}</dd>
        </div>
      ) : departureLabel && (
        <div>
          <dt>Departure window</dt>
          <dd>{departureLabel}</dd>
        </div>
      )}
      {riActivation && (
        <div>
          <dt>RI activation</dt>
          <dd>{riActivation.preferredTiming ?? "Friday morning preferred"}</dd>
        </div>
      )}
      <div>
        <dt>Arrival target</dt>
        <dd>{formatShortDate(itinerary.arriveBy)}</dd>
      </div>
      <div>
        <dt>Activation budget</dt>
        <dd>{String(tripConstraints.activationTimeMinutes ?? 60)} min per stop</dd>
      </div>
      {parkStopPlanning && (
        <div>
          <dt>Broad stop budget</dt>
          <dd>{parkStopPlanning.offHighwayStopHours ?? 2} hr per park stop</dd>
        </div>
      )}
      {roveCounting && (
        <div>
          <dt>Rove count</dt>
          <dd>
            {roveCounting.unit ?? "unique POTA entities"} per{" "}
            {roveCounting.dayBoundary ?? "UTC"} day
          </dd>
        </div>
      )}
      <div>
        <dt>Drive-by detour limit</dt>
        <dd>{String(tripConstraints.maxDetourMinutesForNonOvernightPark ?? 30)} min from I-95</dd>
      </div>
      {vehicle && (
        <div>
          <dt>Charging cadence</dt>
          <dd>
            {vehicle.preferredChargingNetwork ? `${vehicle.preferredChargingNetwork}: ` : ""}
            {vehicle.chargingStopMinutes ?? 30} min after about{" "}
            {vehicle.drivingHoursBetweenChargingStops ?? 2.5} hr driving
          </dd>
        </div>
      )}
      {weekendPlanning && (
        <div>
          <dt>Weekend load</dt>
          <dd>
            {weekendPlanning.candidateHighRoveDay?.status ??
              "No work window; use the weekend for the highest-density rove work."}
          </dd>
        </div>
      )}
      {dcActivation && (
        <div>
          <dt>DC activation</dt>
          <dd>{dcActivation.timing ?? "Mid-week evening preferred"}</dd>
        </div>
      )}
    </dl>

    {requiredJurisdictions.length > 0 && (
      <p class="rove-jurisdictions">
        Activation goal: {requiredJurisdictions.map((s) => s.replace("US-", "")).join(" / ")}
      </p>
    )}
    {roveCounting && (
      <p class="rove-jurisdictions">
        {roveCounting.multiParkRule} {roveCounting.eveningStrategy}
      </p>
    )}
    {riActivation?.notes && <p class="rove-jurisdictions">{riActivation.notes}</p>}
    {parkStopPlanning?.meaning && <p class="rove-jurisdictions">{parkStopPlanning.meaning}</p>}
  </section>

  <section class="section-block wide" aria-labelledby="field-notes-title">
    <div class="section-heading">
      <p class="section-label">Field notes</p>
      <h2 id="field-notes-title">Published trip notes</h2>
    </div>

    <div class="pota-note-links">
      {fieldNotes.map((note) => (
        <a href={note.href}>
          {formatShortDate(note.date)}: {note.title}
        </a>
      ))}
    </div>
    {fieldNotes.map((note) => <p class="rove-weekend-note">{note.summary}</p>)}
  </section>

  <section class="section-block wide" aria-labelledby="navigation-title">
    <div class="section-heading">
      <p class="section-label">Navigation</p>
      <h2 id="navigation-title">Coordinates to punch in</h2>
    </div>

    <div class="rove-coordinate-grid">
      {navigationCoordinates.map((point) => (
        <article>
          <header>
            <span>{point.context}</span>
            <strong>{point.label}</strong>
          </header>
          <dl>
            <div>
              <dt>GPS</dt>
              <dd>
                <a href={googleMapsUrl(point)} target="_blank" rel="noreferrer">
                  {coordinatePair(point)}
                </a>
              </dd>
            </div>
            {point.address && (
              <div>
                <dt>Address</dt>
                <dd>{point.address}</dd>
              </div>
            )}
          </dl>
          {point.reference && (
            <p class="rove-reference-list">
              <a href={potaUrl(point.reference)} target="_blank" rel="noreferrer">
                {point.reference}
              </a>
            </p>
          )}
          <p>{point.notes}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block wide" aria-labelledby="roadmap-title">
    <div class="section-heading">
      <p class="section-label">Working plan</p>
      <h2 id="roadmap-title">High-level roadmap</h2>
    </div>

    {overnightStrategy && (
      <p class="rove-weekend-note">
        Overnight rhythm: {overnightStrategy.recommendedPattern.join(" · ")}.
      </p>
    )}
    <p class="rove-weekend-note">
      Drive times and distances are planning estimates from route checks; park
      activation time is shown separately as the stay budget.
    </p>

    <ol class="rove-timeline-list rove-roadmap-list">
      {overviewStops.map((stop) => (
        <li class={stop.status === "placeholder" ? "rove-roadmap-placeholder" : ""}>
          <div class="rove-timeline-date">{formatShortDate(stop.date)}</div>
          <article class="rove-roadmap-card">
            <div class="rove-card-topline">
              <span>{stop.type}</span>
              {stop.status === "placeholder" && <span>needs selection</span>}
            </div>
            {stop.detailUrl ? (
              <strong>
                <a class="rove-roadmap-title-link" href={stop.detailUrl}>{stop.destination}</a>
              </strong>
            ) : (
              <strong>{stop.destination}</strong>
            )}
            <dl class="rove-roadmap-meta">
              <div>
                <dt>Drive</dt>
