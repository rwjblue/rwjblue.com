---
import "leaflet/dist/leaflet.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import itinerary from "../../../data/pota/rove-to-fl/itinerary.json";

type OvernightType = "hotel" | "home" | "tbd";
interface BookingInfo {
  status: "planned" | "booked" | "n/a";
  confirmation?: string | null;
  url?: string | null;
  notes?: string | null;
}
interface ItineraryDay {
  date: string;
  states: string[];
  overnight: {
    type: OvernightType;
    name: string;
    reference?: string;
    lat?: number;
    lon?: number;
    booking: BookingInfo;
  };
  parkTargets: string[];
  notes?: string;
  approxDriveMiles?: number;
}
interface FridayNightAnchor {
  name: string;
  reference?: string | null;
  state: string;
  overnightType?: string;
  driveFromProvidenceMinutes?: number | null;
  role: string;
  pros: string[];
  cons: string[];
  saturdayImpact?: string;
}
interface CandidateStop {
  reference?: string | null;
  references?: string[];
  name: string;
  state?: string;
  role: string;
  risk?: string;
}
interface RoveTimingModel {
  name: string;
  entityCount: number;
  physicalStops?: number;
  endAnchor: string;
  estimatedDriveMinutes: number;
  estimatedTotalLabel: string;
  comfort: string;
  notes?: string;
  entities?: string[];
}
interface FirstWeekendPlan {
  status: string;
  utcNote: string;
  mdTarget?: {
    localTime: string;
    meaning: string;
    optionalBranch?: string;
  };
  fridayNightAnchors: FridayNightAnchor[];
  parkShortlist?: Array<{
    state: string;
    goal: string;
    defaultReferences: string[];
    options: Array<CandidateStop & {
      latitude: number;
      longitude: number;
      priority: string;
    }>;
  }>;
  saturdayRove: {
    targetDate: string;
    baselineEntityTarget: number;
    stretchEntityTarget: number;
    strategy: string;
    timingAssumptions?: {
      source?: string;
      utcDayRolloverLocal?: string;
    };
    timingModels?: RoveTimingModel[];
    fridayEveningOptions?: Array<{
      name: string;
      route: string;
      estimatedDriveMinutes: number;
      estimatedTotalLabel: string;
      comfort: string;
      notes?: string;
    }>;
    restOfTripComfortRule?: string;
    baselineCandidates: CandidateStop[];
    stretchCandidates: CandidateStop[];
    openQuestions: string[];
  };
  sundayDcRove?: {
    status: string;
    targetDate: string;
    strategy: string;
    timingAssumptions?: {
      source?: string;
      departureArea?: string;
      utcDayRolloverLocal?: string;
    };
    recommendedRoute?: Array<{
      stop: string;
      references: string[];
      role: string;
    }>;
    timingModels?: RoveTimingModel[];
    openQuestions: string[];
  };
}
interface RestOfTripDay {
  date: string;
  overnightType: string;
  startArea: string;
  endArea: string;
  focus: string;
  jurisdictions: string[];
  roughMiles: number;
  roughDriveHours: number;
  chargingHours: number;
  minimumEntities: number;
  parkStopHours?: number;
  roughTotalHours: number;
  notes?: string;
}
interface OvernightStrategyNight {
  date: string;
  preferredType: string;
  area: string;
  why: string;
  savesSeparateParkStop: boolean;
  likelyJurisdictionCoverage: string[];
}
interface OvernightStrategy {
  goal: string;
  recommendedPattern: string[];
  summary: string;
  nights: OvernightStrategyNight[];
  fallbackNote?: string;
}
interface RestOfTripDraft {
  status: string;
  assumptions: string[];
  overnightStrategy?: OvernightStrategy;
  days: RestOfTripDay[];
  risk?: string;
}
interface RoadmapDay {
  date: string;
  route: string;
  focus: string;
  jurisdictions: string[];
  overnightType: string;
  overnightArea: string;
  roughTotalHours?: number;
  notes?: string;
}
interface DriveEstimateLeg {
  date: string;
  from: string;
  to: string;
  distance: string;
  estimatedDriveMinutes: number;
  estimatedDriveLabel: string;
  notes?: string;
}
interface DriveEstimates {
  source: string;
  updated: string;
  legs: DriveEstimateLeg[];
}
interface MapOverlayPoint {
  id?: string;
  label?: string;
  reference?: string;
  name?: string;
  state?: string;
  type?: string;
  status?: string;
  priority?: string;
  goal?: string;
  role?: string;
  latitude: number;
  longitude: number;
  notes?: string;
}
interface MapOverlays {
  anchors: MapOverlayPoint[];
  parkPoints: MapOverlayPoint[];
}

const mapOverlays =
  typeof (itinerary as { mapOverlays?: unknown }).mapOverlays === "object" &&
  (itinerary as { mapOverlays?: unknown }).mapOverlays
    ? ((itinerary as { mapOverlays: MapOverlays }).mapOverlays)
    : { anchors: [], parkPoints: [] };
const mapOverlaysJson = JSON.stringify(mapOverlays);

function formatDate(iso: string) {
  return new Date(`${iso}T12:00:00Z`).toLocaleDateString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}

const tripConstraints = itinerary.constraints as Record<string, unknown>;
const departureWindow = Array.isArray(tripConstraints.departureWindow)
  ? (tripConstraints.departureWindow as string[])
  : [];
const requiredJurisdictions = Array.isArray(tripConstraints.requiredJurisdictions)
  ? (tripConstraints.requiredJurisdictions as string[])
  : [];
const dcActivation =
  typeof tripConstraints.dcActivation === "object" && tripConstraints.dcActivation
    ? (tripConstraints.dcActivation as { timing?: string; notes?: string })
    : null;
const vehicle =
  typeof tripConstraints.vehicle === "object" && tripConstraints.vehicle
    ? (tripConstraints.vehicle as {
        type?: string;
        preferredChargingNetwork?: string;
        chargingStopMinutes?: number;
        drivingHoursBetweenChargingStops?: number;
      })
    : null;
const weekendPlanning =
  typeof tripConstraints.weekendPlanning === "object" && tripConstraints.weekendPlanning
    ? (tripConstraints.weekendPlanning as {
        notes?: string;
        candidateHighRoveDay?: { parkCount?: number; status?: string };
      })
    : null;
const roveCounting =
  typeof tripConstraints.roveCounting === "object" && tripConstraints.roveCounting
    ? (tripConstraints.roveCounting as {
        unit?: string;
        dayBoundary?: string;
        multiParkRule?: string;
        eveningStrategy?: string;
      })
    : null;
const workingDeparture =
  typeof tripConstraints.workingDeparture === "object" && tripConstraints.workingDeparture
    ? (tripConstraints.workingDeparture as {
        date?: string;
        localWindow?: string;
        status?: string;
        notes?: string;
      })
    : null;
const riActivation =
  typeof tripConstraints.riActivation === "object" && tripConstraints.riActivation
    ? (tripConstraints.riActivation as {
        preferredTiming?: string;
        fallbackTiming?: string;
        status?: string;
        notes?: string;
      })
    : null;

function formatShortDate(iso: string) {
  return new Date(`${iso}T12:00:00Z`).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}

const departureLabel =
  departureWindow.length === 2
    ? `${formatShortDate(departureWindow[0])}-${formatShortDate(departureWindow[1])}`
    : departureWindow.map(formatShortDate).join(", ");
const workingDepartureLabel = workingDeparture?.date
  ? `${formatShortDate(workingDeparture.date)} ${workingDeparture.localWindow ?? ""}`.trim()
  : null;
const planningConclusions = Array.isArray(
  (itinerary as { planningConclusions?: unknown }).planningConclusions
)
  ? ((itinerary as { planningConclusions: string[] }).planningConclusions)
  : [];
const firstWeekendPlan =
  typeof (itinerary as { firstWeekendPlan?: unknown }).firstWeekendPlan === "object" &&
  (itinerary as { firstWeekendPlan?: unknown }).firstWeekendPlan
    ? ((itinerary as { firstWeekendPlan: FirstWeekendPlan }).firstWeekendPlan)
    : null;
const restOfTripDraft =
  typeof (itinerary as { restOfTripDraft?: unknown }).restOfTripDraft === "object" &&
  (itinerary as { restOfTripDraft?: unknown }).restOfTripDraft
    ? ((itinerary as { restOfTripDraft: RestOfTripDraft }).restOfTripDraft)
    : null;
const driveEstimates =
  typeof (itinerary as { driveEstimates?: unknown }).driveEstimates === "object" &&
  (itinerary as { driveEstimates?: unknown }).driveEstimates
    ? ((itinerary as { driveEstimates: DriveEstimates }).driveEstimates)
    : null;
const overnightStrategy = restOfTripDraft?.overnightStrategy ?? null;
const itineraryDays = Array.isArray((itinerary as { days?: unknown }).days)
  ? ((itinerary as { days: ItineraryDay[] }).days)
  : [];
const roadmapDays: RoadmapDay[] = itineraryDays.map((day) => ({
  date: day.date,
  route: `${day.states.map((s) => s.replace("US-", "")).join(" / ")} → ${day.overnight.name}`,
  focus: day.notes ?? "",
  jurisdictions: day.states,
  overnightType: day.overnight.type,
  overnightArea: day.overnight.name,
  notes: day.parkTargets.length > 0 ? `Targets: ${day.parkTargets.join(" / ")}` : undefined,
}));
const parkStopPlanning =
  typeof tripConstraints.parkStopPlanning === "object" && tripConstraints.parkStopPlanning
    ? (tripConstraints.parkStopPlanning as {
        offHighwayStopHours?: number;
        meaning?: string;
        overnightParkException?: string;
      })
    : null;
---

<BaseLayout
  title="2026 Rove to FL / N1RWJ"
  description="A week-long POTA activation drive from Rhode Island down the I-95 corridor to Singer Island, FL for Field Day 2026."
  canonicalPath="/projects/2026-06-rove-to-fl/"
>
  <section class="pota-tracker-hero" aria-labelledby="page-title">
    <div>
      <p class="eyebrow">Project / POTA</p>
      <h1 id="page-title">2026 Rove to FL</h1>
      <p class="lede strong">
        I-95 corridor from Rhode Island to Singer Island, FL — activating parks
        along the way and arriving June 26 for Field Day 2026.
      </p>
      <p class="lede">
        Fixed hotel anchors and selected POTA targets are now set through
        Florida. The remaining open park choices are NC, SC, and the exact
        Sunday DC rove flow.
      </p>
    </div>

    <div class="pota-tracker-panel">
      <aside class="pota-scoreboard" aria-label="Trip details">
        <div>
          <strong>Jun 26</strong>
          <span>arrive FL</span>
        </div>
        <div>
          <strong>Jun 27–28</strong>
          <span>Field Day</span>
        </div>
        <div>
          <strong>{mapOverlays.parkPoints.length}</strong>
          <span>target parks</span>
        </div>
        <p>Singer Island / Riviera Beach, FL</p>
      </aside>

      <section class="pota-map-section" aria-labelledby="map-title">
        <div class="section-heading">
          <p class="section-label">Map</p>
          <h2 id="map-title">Trip anchors and targets</h2>
        </div>
        <div id="rove-map" class="pota-map" aria-label="Map of trip hotel anchors and selected POTA targets"></div>
        <div class="pota-map-legend rove-map-legend" aria-label="Map marker legend">
          <span><i style="background:#1f6feb;border-color:#172026"></i>Hotels / anchors</span>
          <span><i style="background:#167246;border-color:#172026"></i>Target parks</span>
          <span><i style="background:#f28e2b;border-color:#172026"></i>Alternate park</span>
        </div>
      </section>
    </div>
  </section>

  <section class="section-block wide" aria-labelledby="planning-title">
    <div class="section-heading">
      <h2 id="planning-title">Planning constraints</h2>
    </div>

    <dl class="rove-constraint-grid">
      {workingDepartureLabel ? (
        <div>
          <dt>Departure</dt>
          <dd>{workingDepartureLabel}</dd>
        </div>
      ) : departureLabel && (
        <div>
          <dt>Departure window</dt>
          <dd>{departureLabel}</dd>
        </div>
      )}
      {riActivation && (
        <div>
          <dt>RI activation</dt>
          <dd>{riActivation.preferredTiming ?? "Friday morning preferred"}</dd>
        </div>
      )}
      <div>
        <dt>Arrival target</dt>
        <dd>{formatShortDate(itinerary.arriveBy)}</dd>
      </div>
      <div>
        <dt>Activation budget</dt>
        <dd>{String(tripConstraints.activationTimeMinutes ?? 60)} min per stop</dd>
      </div>
      {parkStopPlanning && (
        <div>
          <dt>Broad stop budget</dt>
          <dd>{parkStopPlanning.offHighwayStopHours ?? 2} hr per park stop</dd>
        </div>
      )}
      {roveCounting && (
        <div>
          <dt>Rove count</dt>
          <dd>
            {roveCounting.unit ?? "unique POTA entities"} per{" "}
            {roveCounting.dayBoundary ?? "UTC"} day
          </dd>
        </div>
      )}
      <div>
        <dt>Drive-by detour limit</dt>
        <dd>{String(tripConstraints.maxDetourMinutesForNonOvernightPark ?? 30)} min from I-95</dd>
      </div>
      {vehicle && (
        <div>
          <dt>Charging cadence</dt>
          <dd>
            {vehicle.preferredChargingNetwork ? `${vehicle.preferredChargingNetwork}: ` : ""}
            {vehicle.chargingStopMinutes ?? 30} min after about{" "}
            {vehicle.drivingHoursBetweenChargingStops ?? 2.5} hr driving
          </dd>
        </div>
      )}
      {weekendPlanning && (
        <div>
          <dt>Weekend load</dt>
          <dd>
            {weekendPlanning.candidateHighRoveDay?.status ??
              "No work window; use the weekend for the highest-density rove work."}
          </dd>
        </div>
      )}
      {dcActivation && (
        <div>
          <dt>DC activation</dt>
          <dd>{dcActivation.timing ?? "Mid-week evening preferred"}</dd>
        </div>
      )}
    </dl>

    {requiredJurisdictions.length > 0 && (
      <p class="rove-jurisdictions">
        Activation goal: {requiredJurisdictions.map((s) => s.replace("US-", "")).join(" / ")}
      </p>
    )}
    {roveCounting && (
      <p class="rove-jurisdictions">
        {roveCounting.multiParkRule} {roveCounting.eveningStrategy}
      </p>
    )}
    {riActivation?.notes && <p class="rove-jurisdictions">{riActivation.notes}</p>}
    {parkStopPlanning?.meaning && <p class="rove-jurisdictions">{parkStopPlanning.meaning}</p>}
  </section>

  <section class="section-block wide" aria-labelledby="roadmap-title">
    <div class="section-heading">
      <p class="section-label">Working plan</p>
      <h2 id="roadmap-title">High-level roadmap</h2>
    </div>

    {overnightStrategy && (
      <p class="rove-weekend-note">
        Overnight rhythm: {overnightStrategy.recommendedPattern.join(" · ")}.
      </p>
    )}

    <ol class="rove-timeline-list rove-roadmap-list">
      {roadmapDays.map((day) => (
        <li>
          <div class="rove-timeline-date">{formatShortDate(day.date)}</div>
          <div>
            <strong>{day.route}</strong>
            <p>{day.focus}</p>
            <dl class="rove-roadmap-meta">
              <div>
                <dt>Night</dt>
                <dd>{day.overnightType}</dd>
              </div>
              <div>
                <dt>Area</dt>
                <dd>{day.overnightArea}</dd>
              </div>
              {day.roughTotalHours != null && (
                <div>
                  <dt>Budget</dt>
                  <dd>{day.roughTotalHours.toFixed(day.roughTotalHours % 1 === 0 ? 0 : 1)}h</dd>
                </div>
              )}
            </dl>
            <span>{day.jurisdictions.map((s) => s.replace("US-", "")).join(" / ") || "buffer"}</span>
            {day.notes && <p>{day.notes}</p>}
          </div>
        </li>
      ))}
    </ol>

    {restOfTripDraft?.risk && <p class="rove-weekend-note rove-weekend-rule">{restOfTripDraft.risk}</p>}
  </section>

  {driveEstimates && (
    <section class="section-block wide" aria-labelledby="drive-estimates-title">
      <div class="section-heading">
        <p class="section-label">Route budget</p>
        <h2 id="drive-estimates-title">Drive estimates</h2>
      </div>

      <p class="rove-weekend-note">{driveEstimates.source}</p>

      <div class="rove-drive-grid">
        {driveEstimates.legs.map((leg) => (
          <article>
            <span>{formatShortDate(leg.date)}</span>
            <strong>{leg.from} -> {leg.to}</strong>
            <dl>
              <div>
                <dt>Drive</dt>
                <dd>{leg.estimatedDriveLabel}</dd>
              </div>
              <div>
                <dt>Distance</dt>
                <dd>{leg.distance}</dd>
              </div>
            </dl>
            {leg.notes && <p>{leg.notes}</p>}
          </article>
        ))}
      </div>
    </section>
  )}

  {firstWeekendPlan && (
    <section class="section-block wide" aria-labelledby="weekend-title">
      <div class="section-heading">
        <p class="section-label">{firstWeekendPlan.status}</p>
        <h2 id="weekend-title">Selected route targets</h2>
      </div>

      <p class="rove-weekend-note">{firstWeekendPlan.utcNote}</p>
      {firstWeekendPlan.mdTarget && (
        <p class="rove-weekend-note rove-weekend-rule">
          Maryland target: {firstWeekendPlan.mdTarget.localTime}.{" "}
          {firstWeekendPlan.mdTarget.meaning}
        </p>
      )}

      {firstWeekendPlan.parkShortlist && (
        <section aria-labelledby="shortlist-title" class="rove-shortlist-section">
          <h3 id="shortlist-title">Selected parks by leg</h3>
          <div class="rove-shortlist-grid">
            {firstWeekendPlan.parkShortlist.map((group) => (
              <article>
                <header>
                  <strong>{group.state.replace("US-", "")}</strong>
                  <span>{group.goal}</span>
                </header>
                <ul>
                  {group.options.map((option) => (
                    <li>
                      <span class={`rove-priority rove-priority-${option.priority}`}>
                        {option.priority}
                      </span>
                      <strong>
                        {option.reference}
                        {" "}
                        {option.name}
                      </strong>
                      <em>{option.role}</em>
                    </li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </section>
      )}

      <div class="rove-weekend-grid">
        <section aria-labelledby="friday-anchor-title">
          <h3 id="friday-anchor-title">Friday night anchors</h3>
          <div class="rove-anchor-list">
            {firstWeekendPlan.fridayNightAnchors.map((anchor) => (
              <article class="rove-anchor-card">
                <header>
                  <h4>{anchor.name}</h4>
                  {anchor.reference ? (
                    <a
                      href={`https://pota.app/#/park/${anchor.reference}`}
                      target="_blank"
                      rel="noreferrer"
                    >
                      {anchor.reference}
                    </a>
                  ) : (
                    <span>{anchor.state.replace("US-", "")}</span>
                  )}
                </header>
                <p>{anchor.role}</p>
                <p>
                  {anchor.overnightType ? `${anchor.overnightType} · ` : ""}
                  {anchor.driveFromProvidenceMinutes
                    ? `${Math.floor(anchor.driveFromProvidenceMinutes / 60)}h ${anchor.driveFromProvidenceMinutes % 60}m from Providence`
                    : anchor.state.replace("US-", "")}
                </p>
                <ul>
                  {anchor.pros.slice(0, 2).map((pro) => <li>{pro}</li>)}
                </ul>
                {anchor.saturdayImpact && <p>{anchor.saturdayImpact}</p>}
              </article>
            ))}
          </div>
        </section>

        <section aria-labelledby="saturday-candidates-title">
          <h3 id="saturday-candidates-title">Saturday rove shape</h3>
          <p class="rove-weekend-note">{firstWeekendPlan.saturdayRove.strategy}</p>
          {firstWeekendPlan.saturdayRove.timingAssumptions?.source && (
            <p class="rove-weekend-note">
              {firstWeekendPlan.saturdayRove.timingAssumptions.source}
              {firstWeekendPlan.saturdayRove.timingAssumptions.utcDayRolloverLocal &&
                ` UTC rolls at ${firstWeekendPlan.saturdayRove.timingAssumptions.utcDayRolloverLocal}.`}
            </p>
          )}
          <div class="rove-entity-targets">
            <span>{firstWeekendPlan.saturdayRove.baselineEntityTarget} baseline</span>
            <span>{firstWeekendPlan.saturdayRove.stretchEntityTarget} stretch</span>
          </div>
          {firstWeekendPlan.saturdayRove.fridayEveningOptions && (
            <div class="rove-timing-models">
              {firstWeekendPlan.saturdayRove.fridayEveningOptions.map((option) => (
                <article>
                  <strong>{option.name}</strong>
                  <dl>
                    <div>
                      <dt>Drive</dt>
                      <dd>{Math.floor(option.estimatedDriveMinutes / 60)}h {option.estimatedDriveMinutes % 60}m</dd>
                    </div>
                    <div>
                      <dt>Total</dt>
                      <dd>{option.estimatedTotalLabel}</dd>
                    </div>
                  </dl>
                  <p>{option.comfort}. {option.notes}</p>
                </article>
              ))}
            </div>
          )}
          {firstWeekendPlan.saturdayRove.timingModels && (
            <div class="rove-timing-models">
              {firstWeekendPlan.saturdayRove.timingModels.map((model) => (
                <article>
                  <strong>{model.name}</strong>
                  <dl>
                    <div>
                      <dt>Entities</dt>
                      <dd>{model.entityCount}</dd>
                    </div>
                    {model.physicalStops && (
                      <div>
                        <dt>Stops</dt>
                        <dd>{model.physicalStops}</dd>
                      </div>
                    )}
                    <div>
                      <dt>Drive</dt>
                      <dd>{Math.floor(model.estimatedDriveMinutes / 60)}h {model.estimatedDriveMinutes % 60}m</dd>
                    </div>
                    <div>
                      <dt>Total</dt>
                      <dd>{model.estimatedTotalLabel}</dd>
                    </div>
                  </dl>
                  <p>{model.comfort}; ends near {model.endAnchor}</p>
                  {model.entities && (
                    <p>{model.entities.join(" · ")}</p>
                  )}
                </article>
              ))}
            </div>
          )}
          <ol class="rove-candidate-list">
            {firstWeekendPlan.saturdayRove.baselineCandidates.map((candidate) => (
              <li>
                <strong>
                  {candidate.reference ?? "TBD"}
                  {" "}
                  {candidate.name}
                </strong>
                <span>{candidate.state.replace("US-", "")} · {candidate.role}</span>
              </li>
            ))}
          </ol>
        </section>
      </div>

      <section aria-labelledby="stretch-title" class="rove-stretch-section">
        <h3 id="stretch-title">Stretch and verification items</h3>
        <div class="rove-stretch-grid">
          {firstWeekendPlan.saturdayRove.stretchCandidates.map((candidate) => (
            <article>
              <strong>
                {(candidate.references ?? [candidate.reference]).filter(Boolean).join(" + ")}
                {" "}
                {candidate.name}
              </strong>
              <p>{candidate.role}</p>
              {candidate.risk && <span>{candidate.risk}</span>}
            </article>
          ))}
        </div>
        <ul class="rove-conclusions">
          {firstWeekendPlan.saturdayRove.openQuestions.map((question) => <li>{question}</li>)}
        </ul>
      </section>
      {firstWeekendPlan.saturdayRove.restOfTripComfortRule && (
        <p class="rove-weekend-note rove-weekend-rule">
          {firstWeekendPlan.saturdayRove.restOfTripComfortRule}
        </p>
      )}
    </section>
  )}

  {firstWeekendPlan?.sundayDcRove && (
    <section class="section-block wide" aria-labelledby="sunday-dc-title">
      <div class="section-heading">
        <p class="section-label">{firstWeekendPlan.sundayDcRove.status}</p>
        <h2 id="sunday-dc-title">Sunday DC rove branch</h2>
      </div>

      <p class="rove-weekend-note">{firstWeekendPlan.sundayDcRove.strategy}</p>
      {firstWeekendPlan.sundayDcRove.timingAssumptions?.source && (
        <p class="rove-weekend-note">
          {firstWeekendPlan.sundayDcRove.timingAssumptions.source}
          {firstWeekendPlan.sundayDcRove.timingAssumptions.departureArea &&
            ` Starts from ${firstWeekendPlan.sundayDcRove.timingAssumptions.departureArea}.`}
        </p>
      )}

      {firstWeekendPlan.sundayDcRove.recommendedRoute?.length > 0 && (
        <div class="rove-candidate-grid" aria-label="Recommended Sunday DC route">
          {firstWeekendPlan.sundayDcRove.recommendedRoute.map((stop) => (
            <article class="rove-candidate">
              <strong>{stop.stop}</strong>
              <p>{stop.role}</p>
              <span>{stop.references.join(" · ")}</span>
            </article>
          ))}
        </div>
      )}

      {firstWeekendPlan.sundayDcRove.timingModels?.length > 0 && (
        <div class="rove-timing-models">
          {firstWeekendPlan.sundayDcRove.timingModels.map((model) => (
            <article>
              <strong>{model.name}</strong>
              <dl>
                <div>
                  <dt>Entities</dt>
                  <dd>{model.entityCount}</dd>
                </div>
                {model.physicalStops && (
                  <div>
                    <dt>Stops</dt>
                    <dd>{model.physicalStops}</dd>
                  </div>
                )}
                <div>
                  <dt>Drive</dt>
                  <dd>{Math.floor(model.estimatedDriveMinutes / 60)}h {model.estimatedDriveMinutes % 60}m</dd>
                </div>
                <div>
                  <dt>Total</dt>
                  <dd>{model.estimatedTotalLabel}</dd>
                </div>
              </dl>
              <p>{model.comfort}; ends near {model.endAnchor}</p>
              {model.notes && <p>{model.notes}</p>}
              {model.entities && <p>{model.entities.join(" · ")}</p>}
            </article>
          ))}
        </div>
      )}

      <ul class="rove-conclusions">
        {firstWeekendPlan.sundayDcRove.openQuestions.map((question) => <li>{question}</li>)}
      </ul>
    </section>
  )}

  <script type="application/json" id="rove-map-overlays" set:html={mapOverlaysJson} />
  <script>
    import L from "leaflet";

    const overlayEl = document.getElementById("rove-map-overlays");
    const mapEl = document.getElementById("rove-map");

    if (overlayEl && mapEl) {
      const overlays = JSON.parse(overlayEl.textContent ?? "{}");
      const map = L.map(mapEl, { scrollWheelZoom: false });

      L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      }).addTo(map);

      const bounds = L.latLngBounds([]);

      for (const point of overlays.parkPoints ?? []) {
        const color = priorityColor(point.priority);
        const marker = L.circleMarker([point.latitude, point.longitude], {
          radius: point.priority === "alternate" ? 6 : 8,
          color: "#172026",
          weight: 2,
          fillColor: color,
          fillOpacity: 0.95,
        }).addTo(map);

        bounds.extend([point.latitude, point.longitude]);
        marker.bindPopup(planningParkPopup(point));
      }

      for (const anchor of overlays.anchors ?? []) {
        const marker = L.circleMarker([anchor.latitude, anchor.longitude], {
          radius: 7,
          color: "#172026",
          weight: 2,
          fillColor: "#1f6feb",
          fillOpacity: 0.95,
        }).addTo(map);

        bounds.extend([anchor.latitude, anchor.longitude]);
        marker.bindPopup(anchorPopup(anchor));
      }

      if (bounds.isValid()) {
        map.fitBounds(bounds, { padding: [24, 24] });
      }
    }

    function escapeHtml(value: string) {
      return String(value).replace(/[&<>"']/g, (c: string) => {
        const e: Record<string, string> = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" };
        return e[c] ?? c;
      });
    }

    function priorityColor(priority?: string) {
      if (priority === "target" || priority === "default") return "#167246";
      if (priority === "linked") return "#4e79a7";
      if (priority === "alternate" || priority === "optional") return "#f28e2b";
      return "#7f7f7f";
    }

    function planningParkPopup(point: {
      reference?: string;
      name?: string;
      state?: string;
      priority?: string;
      goal?: string;
      role?: string;
    }) {
      const ref = point.reference ?? "TBD";
      return `
        <strong>${escapeHtml(ref)}</strong>
        <span>${escapeHtml(point.name ?? "")}</span>
        <em>${escapeHtml((point.state ?? "").replace("US-", ""))} · ${escapeHtml(point.priority ?? "candidate")}</em>
        <span>${escapeHtml(point.goal ?? "")}</span>
        <span>${escapeHtml(point.role ?? "")}</span>
        ${point.reference ? `<a href="https://pota.app/#/park/${escapeHtml(point.reference)}" target="_blank" rel="noreferrer">POTA page</a>` : ""}
      `;
    }

    function anchorPopup(anchor: {
      label?: string;
      type?: string;
      status?: string;
      notes?: string;
    }) {
      return `
        <strong>${escapeHtml(anchor.label ?? "")}</strong>
        <em>${escapeHtml(anchor.type ?? "anchor")} · ${escapeHtml(anchor.status ?? "")}</em>
        <span>${escapeHtml(anchor.notes ?? "")}</span>
      `;
    }
  </script>
</BaseLayout>

