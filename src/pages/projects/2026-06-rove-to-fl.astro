  <script>
    import L from "leaflet";

    const STATE_COLORS: Record<string, string> = {
      "US-CT": "#4e79a7",
      "US-NY": "#f28e2b",
      "US-NJ": "#e15759",
      "US-DE": "#76b7b2",
      "US-MD": "#59a14f",
      "US-VA": "#edc948",
      "US-NC": "#b07aa1",
      "US-SC": "#ff9da7",
      "US-GA": "#9c755f",
      "US-FL": "#bab0ac",
    };

    const dataEl = document.getElementById("rove-tracker-data");
    const mapEl = document.getElementById("rove-map");

    if (dataEl && mapEl) {
      const tracker = JSON.parse(dataEl.textContent ?? "{}");
      const map = L.map(mapEl, { scrollWheelZoom: false });

      L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      }).addTo(map);

      const bounds = L.latLngBounds([]);

      for (const park of tracker.parks) {
        const color = STATE_COLORS[park.state] ?? "#888";
        const marker = L.circleMarker([park.latitude, park.longitude], {
          radius: 5,
          color: "#172026",
          weight: 1,
          fillColor: color,
          fillOpacity: 0.85,
        }).addTo(map);

        bounds.extend([park.latitude, park.longitude]);
        marker.bindPopup(popupHtml(park));
      }

      if (bounds.isValid()) {
        map.fitBounds(bounds, { padding: [24, 24] });
      }
    }

    function escapeHtml(value: string) {
      return String(value).replace(/[&<>"']/g, (c: string) => {
        const e: Record<string, string> = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" };
        return e[c] ?? c;
      });
    }

    function popupHtml(park: { reference: string; name: string; stateName: string; activations: number; qsos: number }) {
      return `
        <strong>${escapeHtml(park.reference)}</strong>
        <span>${escapeHtml(park.name)}</span>
        <em>${escapeHtml(park.stateName)}</em>
        <span>${park.activations} activations · ${park.qsos} QSOs</span>
        <a href="https://pota.app/#/park/${escapeHtml(park.reference)}" target="_blank" rel="noreferrer">POTA page</a>
      `;
    }
  </script>
