---
import "leaflet/dist/leaflet.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import trackerData from "../../data/pota/rove-to-fl.json";
import itinerary from "../../../data/pota/rove-to-fl/itinerary.json";

const trackerJson = JSON.stringify(trackerData);

// Build a map of POTA ref → park name for itinerary tooltips
const parkByRef = Object.fromEntries(
  trackerData.parks.map((p) => [p.reference, p])
);

// Validate camping-nights constraint and annotate days
type OvernightType = "camp" | "hotel" | "home" | "tbd";
interface BookingInfo {
  status: "planned" | "booked" | "n/a";
  confirmation?: string | null;
  url?: string | null;
  notes?: string | null;
}
interface ItineraryDay {
  date: string;
  states: string[];
  overnight: {
    type: OvernightType;
    name: string;
    reference?: string;
    lat?: number;
    lon?: number;
    booking: BookingInfo;
  };
  parkTargets: string[];
  notes?: string;
  approxDriveMiles?: number;
}
interface TimelineDraftDay {
  date: string;
  area: string;
  focus: string;
  jurisdictions: string[];
  notes?: string;
}
interface TimelineDraft {
  name: string;
  status: string;
  recommendation: string;
  days: TimelineDraftDay[];
}
interface AreaBudget {
  from: string;
  to: string;
  approxMiles: number;
  driveHours: number;
  chargingHours: number;
  minimumActivationEntities: number;
  roughBlockHours: number;
  jurisdictions: string[];
  notes?: string;
}
interface FridayNightAnchor {
  name: string;
  reference: string;
  state: string;
  overnightType?: string;
  driveFromProvidenceMinutes?: number;
  role: string;
  pros: string[];
  cons: string[];
  saturdayImpact?: string;
}
interface CandidateStop {
  reference?: string;
  references?: string[];
  name: string;
  state: string;
  role: string;
  risk?: string;
}
interface FirstWeekendPlan {
  status: string;
  utcNote: string;
  fridayNightAnchors: FridayNightAnchor[];
  saturdayRove: {
    targetDate: string;
    baselineEntityTarget: number;
    stretchEntityTarget: number;
    strategy: string;
    timingAssumptions?: {
      source?: string;
      utcDayRolloverLocal?: string;
    };
    timingModels?: Array<{
      name: string;
      entityCount: number;
      endAnchor: string;
      estimatedDriveMinutes: number;
      estimatedTotalLabel: string;
      comfort: string;
      notes?: string;
    }>;
    fridayEveningOptions?: Array<{
      name: string;
      route: string;
      estimatedDriveMinutes: number;
      estimatedTotalLabel: string;
      comfort: string;
      notes?: string;
    }>;
    restOfTripComfortRule?: string;
    baselineCandidates: CandidateStop[];
    stretchCandidates: CandidateStop[];
    openQuestions: string[];
  };
}
interface RestOfTripDay {
  date: string;
  overnightType: string;
  startArea: string;
  endArea: string;
  focus: string;
  jurisdictions: string[];
  roughMiles: number;
  roughDriveHours: number;
  chargingHours: number;
  minimumEntities: number;
  parkStopHours?: number;
  roughTotalHours: number;
  notes?: string;
}
interface OvernightStrategyNight {
  date: string;
  preferredType: string;
  area: string;
  why: string;
  savesSeparateParkStop: boolean;
  likelyJurisdictionCoverage: string[];
}
interface OvernightStrategy {
  goal: string;
  recommendedPattern: string[];
  summary: string;
  nights: OvernightStrategyNight[];
  fallbackNote?: string;
}
interface RestOfTripDraft {
  status: string;
  assumptions: string[];
  overnightStrategy?: OvernightStrategy;
  days: RestOfTripDay[];
  risk?: string;
}
interface NferLead {
  status: string;
  summary: string;
  references: string[];
  notes?: string;
  routingNote?: string;
  exampleActivator?: string;
  exampleActivators?: string[];
  exampleDate?: string;
}
interface NferEvidence {
  sourceDescription: string;
  recordCount: number;
  currentRead: string;
  saturday: NferLead[];
  sunday: NferLead[];
}
interface CampingPolicyNotes {
  status: string;
  currentRead: string;
  carCampingRead?: string;
  jurisdictions: Array<{
    state: string;
    risk: string;
    summary: string;
  }>;
}
interface RoadmapDay {
  date: string;
  route: string;
  focus: string;
  jurisdictions: string[];
  overnightType: string;
  overnightArea: string;
  roughTotalHours?: number;
  notes?: string;
}

let consecutiveCamp = 0;
const annotatedDays = (itinerary.days as ItineraryDay[]).map((day) => {
  const isCamp = day.overnight.type === "camp";
  if (isCamp) {
    consecutiveCamp += 1;
  } else {
    consecutiveCamp = 0;
  }
  return {
    ...day,
    consecutiveCampCount: isCamp ? consecutiveCamp : 0,
    campViolation: consecutiveCamp > itinerary.constraints.maxConsecutiveCampNights,
  };
});

function formatDate(iso: string) {
  return new Date(`${iso}T12:00:00Z`).toLocaleDateString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}

const OVERNIGHT_ICON: Record<OvernightType, string> = {
  camp: "⛺",
  hotel: "🏨",
  home: "🏠",
  tbd: "?",
};

// Colors assigned in route order (CT → FL)
const STATE_COLORS: Record<string, string> = {
  "US-CT": "#4e79a7",
  "US-NY": "#f28e2b",
  "US-NJ": "#e15759",
  "US-DE": "#76b7b2",
  "US-MD": "#59a14f",
  "US-VA": "#edc948",
  "US-NC": "#b07aa1",
  "US-SC": "#ff9da7",
  "US-GA": "#9c755f",
  "US-FL": "#bab0ac",
};

const tripConstraints = itinerary.constraints as Record<string, unknown>;
const departureWindow = Array.isArray(tripConstraints.departureWindow)
  ? (tripConstraints.departureWindow as string[])
  : [];
const requiredJurisdictions = Array.isArray(tripConstraints.requiredJurisdictions)
  ? (tripConstraints.requiredJurisdictions as string[])
  : [];
const dcActivation =
  typeof tripConstraints.dcActivation === "object" && tripConstraints.dcActivation
    ? (tripConstraints.dcActivation as { timing?: string; notes?: string })
    : null;
const vehicle =
  typeof tripConstraints.vehicle === "object" && tripConstraints.vehicle
    ? (tripConstraints.vehicle as {
        type?: string;
        preferredChargingNetwork?: string;
        chargingStopMinutes?: number;
        drivingHoursBetweenChargingStops?: number;
      })
    : null;
const weekendPlanning =
  typeof tripConstraints.weekendPlanning === "object" && tripConstraints.weekendPlanning
    ? (tripConstraints.weekendPlanning as {
        notes?: string;
        candidateHighRoveDay?: { parkCount?: number; status?: string };
      })
    : null;
const roveCounting =
  typeof tripConstraints.roveCounting === "object" && tripConstraints.roveCounting
    ? (tripConstraints.roveCounting as {
        unit?: string;
        dayBoundary?: string;
        multiParkRule?: string;
        eveningStrategy?: string;
      })
    : null;
const workingDeparture =
  typeof tripConstraints.workingDeparture === "object" && tripConstraints.workingDeparture
    ? (tripConstraints.workingDeparture as {
        date?: string;
        localWindow?: string;
        status?: string;
        notes?: string;
      })
    : null;
const riActivation =
  typeof tripConstraints.riActivation === "object" && tripConstraints.riActivation
    ? (tripConstraints.riActivation as {
        preferredTiming?: string;
        fallbackTiming?: string;
        status?: string;
        notes?: string;
      })
    : null;

function formatShortDate(iso: string) {
  return new Date(`${iso}T12:00:00Z`).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}

const departureLabel =
  departureWindow.length === 2
    ? `${formatShortDate(departureWindow[0])}-${formatShortDate(departureWindow[1])}`
    : departureWindow.map(formatShortDate).join(", ");
const workingDepartureLabel = workingDeparture?.date
  ? `${formatShortDate(workingDeparture.date)} ${workingDeparture.localWindow ?? ""}`.trim()
  : null;
const timelineDrafts = Array.isArray((itinerary as { timelineDrafts?: unknown }).timelineDrafts)
  ? ((itinerary as { timelineDrafts: TimelineDraft[] }).timelineDrafts)
  : [];
const areaBudgets = Array.isArray((itinerary as { areaBudgets?: unknown }).areaBudgets)
  ? ((itinerary as { areaBudgets: AreaBudget[] }).areaBudgets)
  : [];
const planningConclusions = Array.isArray(
  (itinerary as { planningConclusions?: unknown }).planningConclusions
)
  ? ((itinerary as { planningConclusions: string[] }).planningConclusions)
  : [];
const firstWeekendPlan =
  typeof (itinerary as { firstWeekendPlan?: unknown }).firstWeekendPlan === "object" &&
  (itinerary as { firstWeekendPlan?: unknown }).firstWeekendPlan
    ? ((itinerary as { firstWeekendPlan: FirstWeekendPlan }).firstWeekendPlan)
    : null;
const restOfTripDraft =
  typeof (itinerary as { restOfTripDraft?: unknown }).restOfTripDraft === "object" &&
  (itinerary as { restOfTripDraft?: unknown }).restOfTripDraft
    ? ((itinerary as { restOfTripDraft: RestOfTripDraft }).restOfTripDraft)
    : null;
const nferEvidence =
  typeof (itinerary as { nferEvidence?: unknown }).nferEvidence === "object" &&
  (itinerary as { nferEvidence?: unknown }).nferEvidence
    ? ((itinerary as { nferEvidence: NferEvidence }).nferEvidence)
    : null;
const campingPolicyNotes =
  typeof (itinerary as { campingPolicyNotes?: unknown }).campingPolicyNotes === "object" &&
  (itinerary as { campingPolicyNotes?: unknown }).campingPolicyNotes
    ? ((itinerary as { campingPolicyNotes: CampingPolicyNotes }).campingPolicyNotes)
    : null;
const overnightStrategy = restOfTripDraft?.overnightStrategy ?? null;
const roadmapDays: RoadmapDay[] = [
  {
    date: "2026-06-19",
    route: "Providence → CT coast / lower Hudson",
    focus: "Depart after work and choose how far west to reposition based on the Saturday rove target.",
    jurisdictions: ["US-RI", "US-CT"],
    overnightType: "camp or hotel",
    overnightArea: "Milford, Stamford, or Tallman",
    roughTotalHours: 1.3,
    notes: "Hammonasset is now a standby-only camp option because one-night advance reservations are not reliable; Milford/Stamford/Tallman are the realistic anchors.",
  },
  {
    date: "2026-06-20",
    route: "CT / lower Hudson → NJ / DE",
    focus: "Primary 10-entity UTC rove attempt, with a 15-entity stretch only if Friday-night UTC credit and verified n-fers line up.",
    jurisdictions: ["US-CT", "US-NY", "US-NJ"],
    overnightType: "hotel",
    overnightArea: "Central or south New Jersey",
    roughTotalHours: 15.25,
    notes: "Milford/Silver Sands currently looks like the best compromise; Hammonasset is no longer the default because of campsite minimum-stay rules.",
  },
  ...(restOfTripDraft?.days ?? []).map((day) => ({
    date: day.date,
    route: `${day.startArea} → ${day.endArea}`,
    focus: day.focus,
    jurisdictions: day.jurisdictions,
    overnightType: day.overnightType,
    overnightArea: day.endArea,
    roughTotalHours: day.roughTotalHours,
    notes: day.notes,
  })),
];
const campArrival =
  typeof tripConstraints.campArrival === "object" && tripConstraints.campArrival
    ? (tripConstraints.campArrival as {
        targetLatestArrival?: string;
        reason?: string;
        activationTiming?: string;
      })
    : null;
const parkStopPlanning =
  typeof tripConstraints.parkStopPlanning === "object" && tripConstraints.parkStopPlanning
    ? (tripConstraints.parkStopPlanning as {
        offHighwayStopHours?: number;
        meaning?: string;
        overnightParkException?: string;
      })
    : null;
---

<BaseLayout
  title="2026 Rove to FL / N1RWJ"
  description="A week-long POTA activation drive from Rhode Island down the I-95 corridor to Singer Island, FL for Field Day 2026."
  canonicalPath="/projects/2026-06-rove-to-fl/"
>
  <section class="pota-tracker-hero" aria-labelledby="page-title">
    <div>
      <p class="eyebrow">Project / POTA</p>
      <h1 id="page-title">2026 Rove to FL</h1>
      <p class="lede strong">
        I-95 corridor from Rhode Island to Singer Island, FL — activating parks
        along the way and arriving June 26 for Field Day 2026.
      </p>
      <p class="lede">
        {trackerData.parks.length} parks along the corridor across {trackerData.route.length} states.
        Targets TBD.
      </p>
    </div>

    <div class="pota-tracker-panel">
      <aside class="pota-scoreboard" aria-label="Trip details">
        <div>
          <strong>Jun 26</strong>
          <span>arrive FL</span>
        </div>
        <div>
          <strong>Jun 27–28</strong>
          <span>Field Day</span>
        </div>
        <div>
          <strong>{trackerData.parks.length}</strong>
          <span>corridor parks</span>
        </div>
        <p>Singer Island / Riviera Beach, FL</p>
      </aside>

      <section class="pota-map-section" aria-labelledby="map-title">
        <div class="section-heading">
          <p class="section-label">Map</p>
          <h2 id="map-title">I-95 corridor parks</h2>
        </div>
        <div id="rove-map" class="pota-map" aria-label="Map of I-95 corridor POTA parks"></div>
        <div class="pota-map-legend rove-map-legend" aria-label="State color legend">
          {trackerData.route.map((s) => (
            <span>
              <i style={`background:${STATE_COLORS[s.code] ?? "#888"};border-color:#172026`}></i>
              {s.code.replace("US-", "")}
            </span>
          ))}
        </div>
      </section>
    </div>
  </section>

  <section class="section-block wide" aria-labelledby="states-title">
    <div class="section-heading">
      <h2 id="states-title">Parks by state</h2>
    </div>
    <div class="rove-state-grid">
      {trackerData.route.map((s) => (
        <div class="rove-state-card">
          <span
            class="rove-state-dot"
            style={`background:${STATE_COLORS[s.code] ?? "#888"}`}
            aria-hidden="true"
          ></span>
          <span class="rove-state-abbr">{s.code.replace("US-", "")}</span>
          <span class="rove-state-name">{s.name}</span>
          <span class="rove-state-count">{s.corridorCount}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section-block wide" aria-labelledby="planning-title">
    <div class="section-heading">
      <h2 id="planning-title">Planning constraints</h2>
    </div>

    <dl class="rove-constraint-grid">
      {workingDepartureLabel ? (
        <div>
          <dt>Departure</dt>
          <dd>{workingDepartureLabel}</dd>
        </div>
      ) : departureLabel && (
        <div>
          <dt>Departure window</dt>
          <dd>{departureLabel}</dd>
        </div>
      )}
      {riActivation && (
        <div>
          <dt>RI activation</dt>
          <dd>{riActivation.preferredTiming ?? "Friday morning preferred"}</dd>
        </div>
      )}
      <div>
        <dt>Arrival target</dt>
        <dd>{formatShortDate(itinerary.arriveBy)}</dd>
      </div>
      <div>
        <dt>Activation budget</dt>
        <dd>{String(tripConstraints.activationTimeMinutes ?? 60)} min per stop</dd>
      </div>
      {parkStopPlanning && (
        <div>
          <dt>Broad stop budget</dt>
          <dd>{parkStopPlanning.offHighwayStopHours ?? 2} hr per park stop</dd>
        </div>
      )}
      {roveCounting && (
        <div>
          <dt>Rove count</dt>
          <dd>
            {roveCounting.unit ?? "unique POTA entities"} per{" "}
            {roveCounting.dayBoundary ?? "UTC"} day
          </dd>
        </div>
      )}
      <div>
        <dt>Drive-by detour limit</dt>
        <dd>{String(tripConstraints.maxDetourMinutesForNonOvernightPark ?? 30)} min from I-95</dd>
      </div>
      <div>
        <dt>Camping rhythm</dt>
        <dd>
          POTA parks for at least half the nights; max{" "}
          {itinerary.constraints.maxConsecutiveCampNights} in a row
        </dd>
      </div>
      {vehicle && (
        <div>
          <dt>Charging cadence</dt>
          <dd>
            {vehicle.preferredChargingNetwork ? `${vehicle.preferredChargingNetwork}: ` : ""}
            {vehicle.chargingStopMinutes ?? 30} min after about{" "}
            {vehicle.drivingHoursBetweenChargingStops ?? 2.5} hr driving
          </dd>
        </div>
      )}
      {campArrival && (
        <div>
          <dt>Camp arrival</dt>
          <dd>{campArrival.targetLatestArrival ?? "18:30-19:00"}</dd>
        </div>
      )}
      {weekendPlanning && (
        <div>
          <dt>Weekend load</dt>
          <dd>
            No work window; {weekendPlanning.candidateHighRoveDay?.parkCount ?? 10}-park
            rove idea to evaluate
          </dd>
        </div>
      )}
      {dcActivation && (
        <div>
          <dt>DC activation</dt>
          <dd>{dcActivation.timing ?? "Mid-week evening preferred"}</dd>
        </div>
      )}
    </dl>

    {requiredJurisdictions.length > 0 && (
      <p class="rove-jurisdictions">
        Activation goal: {requiredJurisdictions.map((s) => s.replace("US-", "")).join(" / ")}
      </p>
    )}
    {roveCounting && (
      <p class="rove-jurisdictions">
        {roveCounting.multiParkRule} {roveCounting.eveningStrategy}
      </p>
    )}
    {riActivation?.notes && <p class="rove-jurisdictions">{riActivation.notes}</p>}
    {parkStopPlanning?.meaning && <p class="rove-jurisdictions">{parkStopPlanning.meaning}</p>}
  </section>

  <section class="section-block wide" aria-labelledby="roadmap-title">
    <div class="section-heading">
      <p class="section-label">Working plan</p>
      <h2 id="roadmap-title">High-level roadmap</h2>
    </div>

    {overnightStrategy && (
      <p class="rove-weekend-note">
        Overnight rhythm: {overnightStrategy.recommendedPattern.join(" · ")}.
      </p>
    )}

    <ol class="rove-timeline-list rove-roadmap-list">
      {roadmapDays.map((day) => (
        <li>
          <div class="rove-timeline-date">{formatShortDate(day.date)}</div>
          <div>
            <strong>{day.route}</strong>
            <p>{day.focus}</p>
            <dl class="rove-roadmap-meta">
              <div>
                <dt>Night</dt>
                <dd>{day.overnightType}</dd>
              </div>
              <div>
                <dt>Area</dt>
                <dd>{day.overnightArea}</dd>
              </div>
              {day.roughTotalHours != null && (
                <div>
                  <dt>Budget</dt>
                  <dd>{day.roughTotalHours.toFixed(day.roughTotalHours % 1 === 0 ? 0 : 1)}h</dd>
                </div>
              )}
            </dl>
            <span>{day.jurisdictions.map((s) => s.replace("US-", "")).join(" / ") || "buffer"}</span>
            {day.notes && <p>{day.notes}</p>}
          </div>
        </li>
      ))}
    </ol>

    {restOfTripDraft?.risk && <p class="rove-weekend-note rove-weekend-rule">{restOfTripDraft.risk}</p>}
  </section>

  {firstWeekendPlan && (
    <section class="section-block wide" aria-labelledby="weekend-title">
      <div class="section-heading">
        <p class="section-label">{firstWeekendPlan.status}</p>
        <h2 id="weekend-title">First weekend candidates</h2>
      </div>

      <p class="rove-weekend-note">{firstWeekendPlan.utcNote}</p>

      <div class="rove-weekend-grid">
        <section aria-labelledby="friday-anchor-title">
          <h3 id="friday-anchor-title">Friday night anchors</h3>
          <div class="rove-anchor-list">
            {firstWeekendPlan.fridayNightAnchors.map((anchor) => (
              <article class="rove-anchor-card">
                <header>
                  <h4>{anchor.name}</h4>
                  <a
                    href={`https://pota.app/#/park/${anchor.reference}`}
                    target="_blank"
                    rel="noreferrer"
                  >
                    {anchor.reference}
                  </a>
                </header>
                <p>{anchor.role}</p>
                <p>
                  {anchor.overnightType ? `${anchor.overnightType} · ` : ""}
                  {anchor.driveFromProvidenceMinutes
                    ? `${Math.floor(anchor.driveFromProvidenceMinutes / 60)}h ${anchor.driveFromProvidenceMinutes % 60}m from Providence`
                    : anchor.state.replace("US-", "")}
                </p>
                <ul>
                  {anchor.pros.slice(0, 2).map((pro) => <li>{pro}</li>)}
                </ul>
                {anchor.saturdayImpact && <p>{anchor.saturdayImpact}</p>}
              </article>
            ))}
          </div>
        </section>

        <section aria-labelledby="saturday-candidates-title">
          <h3 id="saturday-candidates-title">Saturday rove shape</h3>
          <p class="rove-weekend-note">{firstWeekendPlan.saturdayRove.strategy}</p>
          {firstWeekendPlan.saturdayRove.timingAssumptions?.source && (
            <p class="rove-weekend-note">
              {firstWeekendPlan.saturdayRove.timingAssumptions.source}
              {firstWeekendPlan.saturdayRove.timingAssumptions.utcDayRolloverLocal &&
                ` UTC rolls at ${firstWeekendPlan.saturdayRove.timingAssumptions.utcDayRolloverLocal}.`}
            </p>
          )}
          <div class="rove-entity-targets">
            <span>{firstWeekendPlan.saturdayRove.baselineEntityTarget} baseline</span>
            <span>{firstWeekendPlan.saturdayRove.stretchEntityTarget} stretch</span>
          </div>
          {firstWeekendPlan.saturdayRove.fridayEveningOptions && (
            <div class="rove-timing-models">
              {firstWeekendPlan.saturdayRove.fridayEveningOptions.map((option) => (
                <article>
                  <strong>{option.name}</strong>
                  <dl>
                    <div>
                      <dt>Drive</dt>
                      <dd>{Math.floor(option.estimatedDriveMinutes / 60)}h {option.estimatedDriveMinutes % 60}m</dd>
                    </div>
                    <div>
                      <dt>Total</dt>
                      <dd>{option.estimatedTotalLabel}</dd>
                    </div>
                  </dl>
                  <p>{option.comfort}. {option.notes}</p>
                </article>
              ))}
            </div>
          )}
          {firstWeekendPlan.saturdayRove.timingModels && (
            <div class="rove-timing-models">
              {firstWeekendPlan.saturdayRove.timingModels.map((model) => (
                <article>
                  <strong>{model.name}</strong>
                  <dl>
                    <div>
                      <dt>Entities</dt>
                      <dd>{model.entityCount}</dd>
                    </div>
                    <div>
                      <dt>Drive</dt>
                      <dd>{Math.floor(model.estimatedDriveMinutes / 60)}h {model.estimatedDriveMinutes % 60}m</dd>
                    </div>
                    <div>
                      <dt>Total</dt>
                      <dd>{model.estimatedTotalLabel}</dd>
                    </div>
                  </dl>
                  <p>{model.comfort}; ends near {model.endAnchor}</p>
                </article>
              ))}
            </div>
          )}
          <ol class="rove-candidate-list">
            {firstWeekendPlan.saturdayRove.baselineCandidates.map((candidate) => (
              <li>
                <strong>
                  {candidate.reference}
                  {" "}
                  {candidate.name}
                </strong>
                <span>{candidate.state.replace("US-", "")} · {candidate.role}</span>
              </li>
            ))}
          </ol>
        </section>
      </div>

      <section aria-labelledby="stretch-title" class="rove-stretch-section">
        <h3 id="stretch-title">Stretch and verification items</h3>
        <div class="rove-stretch-grid">
          {firstWeekendPlan.saturdayRove.stretchCandidates.map((candidate) => (
            <article>
              <strong>
                {(candidate.references ?? [candidate.reference]).filter(Boolean).join(" + ")}
                {" "}
                {candidate.name}
              </strong>
              <p>{candidate.role}</p>
              {candidate.risk && <span>{candidate.risk}</span>}
            </article>
          ))}
        </div>
        <ul class="rove-conclusions">
