---
import "leaflet/dist/leaflet.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import trackerData from "../../data/pota/rove-to-fl.json";
import itinerary from "../../../data/pota/rove-to-fl/itinerary.json";

const trackerJson = JSON.stringify(trackerData);

// Build a map of POTA ref → park name for itinerary tooltips
const parkByRef = Object.fromEntries(
  trackerData.parks.map((p) => [p.reference, p])
);

// Validate camping-nights constraint and annotate days
type OvernightType = "camp" | "hotel" | "home" | "tbd";
interface BookingInfo {
  status: "planned" | "booked" | "n/a";
  confirmation?: string | null;
  url?: string | null;
  notes?: string | null;
}
interface ItineraryDay {
  date: string;
  states: string[];
  overnight: {
    type: OvernightType;
    name: string;
    reference?: string;
    lat?: number;
    lon?: number;
    booking: BookingInfo;
  };
  parkTargets: string[];
  notes?: string;
  approxDriveMiles?: number;
}

let consecutiveCamp = 0;
const annotatedDays = (itinerary.days as ItineraryDay[]).map((day) => {
  const isCamp = day.overnight.type === "camp";
  if (isCamp) {
    consecutiveCamp += 1;
  } else {
    consecutiveCamp = 0;
  }
  return {
    ...day,
    consecutiveCampCount: isCamp ? consecutiveCamp : 0,
    campViolation: consecutiveCamp > itinerary.constraints.maxConsecutiveCampNights,
  };
});

function formatDate(iso: string) {
  return new Date(`${iso}T12:00:00Z`).toLocaleDateString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}

const OVERNIGHT_ICON: Record<OvernightType, string> = {
  camp: "⛺",
  hotel: "🏨",
  home: "🏠",
  tbd: "?",
};

// Colors assigned in route order (CT → FL)
const STATE_COLORS: Record<string, string> = {
  "US-CT": "#4e79a7",
  "US-NY": "#f28e2b",
  "US-NJ": "#e15759",
  "US-DE": "#76b7b2",
  "US-MD": "#59a14f",
  "US-VA": "#edc948",
  "US-NC": "#b07aa1",
  "US-SC": "#ff9da7",
  "US-GA": "#9c755f",
  "US-FL": "#bab0ac",
};

const tripConstraints = itinerary.constraints as Record<string, unknown>;
const departureWindow = Array.isArray(tripConstraints.departureWindow)
  ? (tripConstraints.departureWindow as string[])
  : [];
const requiredJurisdictions = Array.isArray(tripConstraints.requiredJurisdictions)
  ? (tripConstraints.requiredJurisdictions as string[])
  : [];
const dcActivation =
  typeof tripConstraints.dcActivation === "object" && tripConstraints.dcActivation
    ? (tripConstraints.dcActivation as { timing?: string; notes?: string })
    : null;
const vehicle =
  typeof tripConstraints.vehicle === "object" && tripConstraints.vehicle
    ? (tripConstraints.vehicle as {
        type?: string;
        chargingStopMinutes?: number;
        drivingHoursBetweenChargingStops?: number;
      })
    : null;
const weekendPlanning =
  typeof tripConstraints.weekendPlanning === "object" && tripConstraints.weekendPlanning
    ? (tripConstraints.weekendPlanning as {
        notes?: string;
        candidateHighRoveDay?: { parkCount?: number; status?: string };
      })
    : null;

function formatShortDate(iso: string) {
  return new Date(`${iso}T12:00:00Z`).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}

const departureLabel =
  departureWindow.length === 2
    ? `${formatShortDate(departureWindow[0])}-${formatShortDate(departureWindow[1])}`
    : departureWindow.map(formatShortDate).join(", ");
---

<BaseLayout
  title="2026 Rove to FL / N1RWJ"
  description="A week-long POTA activation drive from Rhode Island down the I-95 corridor to Singer Island, FL for Field Day 2026."
  canonicalPath="/projects/2026-06-rove-to-fl/"
>
  <section class="pota-tracker-hero" aria-labelledby="page-title">
    <div>
      <p class="eyebrow">Project / POTA</p>
      <h1 id="page-title">2026 Rove to FL</h1>
      <p class="lede strong">
        I-95 corridor from Rhode Island to Singer Island, FL — activating parks
        along the way and arriving June 26 for Field Day 2026.
      </p>
      <p class="lede">
        {trackerData.parks.length} parks along the corridor across {trackerData.route.length} states.
        Targets TBD.
      </p>
    </div>

    <div class="pota-tracker-panel">
      <aside class="pota-scoreboard" aria-label="Trip details">
        <div>
          <strong>Jun 26</strong>
          <span>arrive FL</span>
        </div>
        <div>
          <strong>Jun 27–28</strong>
          <span>Field Day</span>
        </div>
        <div>
          <strong>{trackerData.parks.length}</strong>
          <span>corridor parks</span>
        </div>
        <p>Singer Island / Riviera Beach, FL</p>
      </aside>

      <section class="pota-map-section" aria-labelledby="map-title">
        <div class="section-heading">
          <p class="section-label">Map</p>
          <h2 id="map-title">I-95 corridor parks</h2>
        </div>
        <div id="rove-map" class="pota-map" aria-label="Map of I-95 corridor POTA parks"></div>
        <div class="pota-map-legend rove-map-legend" aria-label="State color legend">
          {trackerData.route.map((s) => (
            <span>
              <i style={`background:${STATE_COLORS[s.code] ?? "#888"};border-color:#172026`}></i>
              {s.code.replace("US-", "")}
            </span>
          ))}
        </div>
      </section>
    </div>
  </section>

  <section class="section-block wide" aria-labelledby="states-title">
    <div class="section-heading">
      <h2 id="states-title">Parks by state</h2>
    </div>
    <div class="rove-state-grid">
      {trackerData.route.map((s) => (
        <div class="rove-state-card">
          <span
            class="rove-state-dot"
            style={`background:${STATE_COLORS[s.code] ?? "#888"}`}
            aria-hidden="true"
          ></span>
          <span class="rove-state-abbr">{s.code.replace("US-", "")}</span>
          <span class="rove-state-name">{s.name}</span>
          <span class="rove-state-count">{s.corridorCount}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section-block wide" aria-labelledby="planning-title">
    <div class="section-heading">
      <h2 id="planning-title">Planning constraints</h2>
    </div>

    <dl class="rove-constraint-grid">
      {departureLabel && (
        <div>
          <dt>Departure window</dt>
          <dd>{departureLabel}</dd>
        </div>
      )}
      <div>
        <dt>Arrival target</dt>
        <dd>{formatShortDate(itinerary.arriveBy)}</dd>
      </div>
      <div>
        <dt>Activation budget</dt>
        <dd>{String(tripConstraints.activationTimeMinutes ?? 60)} min per stop</dd>
      </div>
      <div>
        <dt>Drive-by detour limit</dt>
        <dd>{String(tripConstraints.maxDetourMinutesForNonOvernightPark ?? 30)} min from I-95</dd>
      </div>
      <div>
        <dt>Camping rhythm</dt>
        <dd>
          POTA parks for at least half the nights; max{" "}
          {itinerary.constraints.maxConsecutiveCampNights} in a row
        </dd>
      </div>
      {vehicle && (
        <div>
          <dt>Charging cadence</dt>
          <dd>
            {vehicle.chargingStopMinutes ?? 30} min after about{" "}
            {vehicle.drivingHoursBetweenChargingStops ?? 2.5} hr driving
          </dd>
        </div>
      )}
      {weekendPlanning && (
        <div>
          <dt>Weekend load</dt>
          <dd>
            No work window; {weekendPlanning.candidateHighRoveDay?.parkCount ?? 10}-park
            rove idea to evaluate
          </dd>
        </div>
      )}
      {dcActivation && (
        <div>
          <dt>DC activation</dt>
          <dd>{dcActivation.timing ?? "Mid-week evening preferred"}</dd>
        </div>
      )}
    </dl>

    {requiredJurisdictions.length > 0 && (
      <p class="rove-jurisdictions">
        Activation goal: {requiredJurisdictions.map((s) => s.replace("US-", "")).join(" / ")}
      </p>
    )}
  </section>

  <section class="section-block wide" aria-labelledby="itinerary-title">
    <div class="section-heading">
      <h2 id="itinerary-title">Itinerary</h2>
    </div>

    {annotatedDays.length === 0 ? (
      <div class="rove-itinerary-empty">
        <p>Planning in progress. Days will appear here as the itinerary is drafted.</p>
        <p class="meta">
          Work window: {itinerary.constraints.workStart}–{itinerary.constraints.workEnd} local ·
          Max {itinerary.constraints.maxConsecutiveCampNights} consecutive camping nights ·
          Arrive by {itinerary.arriveBy}
        </p>
      </div>
    ) : (
      <div class="rove-itinerary">
        <p class="meta rove-constraints">
          Work {itinerary.constraints.workStart}–{itinerary.constraints.workEnd} local ·
          max {itinerary.constraints.maxConsecutiveCampNights} consecutive camping nights ·
          arrive by {itinerary.arriveBy}
        </p>
        <ol class="rove-day-list">
          {annotatedDays.map((day, i) => (
            <li class={`rove-day${day.campViolation ? " rove-day--violation" : ""}`}>
              <div class="rove-day-header">
                <span class="rove-day-number">Day {i + 1}</span>
                <span class="rove-day-date">{formatDate(day.date)}</span>
                {day.approxDriveMiles && (
                  <span class="rove-day-miles">{day.approxDriveMiles} mi</span>
                )}
                <span class="rove-day-states">
                  {day.states.map((s) => s.replace("US-", "")).join(" · ")}
                </span>
              </div>

              <div class="rove-day-body">
                <div class="rove-overnight">
                  <span class="rove-overnight-icon" title={day.overnight.type}>
                    {OVERNIGHT_ICON[day.overnight.type as OvernightType]}
                  </span>
                  <span class="rove-overnight-name">{day.overnight.name}</span>
                  {day.overnight.reference && (
                    <a
                      class="rove-overnight-ref"
                      href={`https://pota.app/#/park/${day.overnight.reference}`}
                      target="_blank"
                      rel="noreferrer"
                    >
                      {day.overnight.reference}
                    </a>
                  )}
                  <span class={`rove-booking-status rove-booking-${day.overnight.booking.status}`}>
                    {day.overnight.booking.status}
                    {day.overnight.booking.confirmation && (
                      <span> · #{day.overnight.booking.confirmation}</span>
                    )}
                  </span>
                  {day.campViolation && (
                    <span class="rove-camp-warning" title="Exceeds max consecutive camping nights">
                      ⚠ camp limit
                    </span>
                  )}
                </div>

                {day.parkTargets.length > 0 && (
                  <ul class="rove-park-targets">
                    {day.parkTargets.map((ref) => {
                      const park = parkByRef[ref];
                      return (
                        <li>
                          <a
                            href={`https://pota.app/#/park/${ref}`}
                            target="_blank"
                            rel="noreferrer"
                          >
                            {ref}
                          </a>
                          {park && <span> {park.name}</span>}
                        </li>
                      );
                    })}
                  </ul>
                )}

                {day.notes && <p class="rove-day-notes">{day.notes}</p>}
              </div>
            </li>
          ))}
        </ol>
      </div>
    )}
  </section>

  <script type="application/json" id="rove-tracker-data" set:html={trackerJson} />
  <script>
    import L from "leaflet";

    const STATE_COLORS: Record<string, string> = {
      "US-CT": "#4e79a7",
      "US-NY": "#f28e2b",
      "US-NJ": "#e15759",
      "US-DE": "#76b7b2",
      "US-MD": "#59a14f",
      "US-VA": "#edc948",
      "US-NC": "#b07aa1",
      "US-SC": "#ff9da7",
      "US-GA": "#9c755f",
      "US-FL": "#bab0ac",
    };

    const dataEl = document.getElementById("rove-tracker-data");
    const mapEl = document.getElementById("rove-map");

    if (dataEl && mapEl) {
      const tracker = JSON.parse(dataEl.textContent ?? "{}");
      const map = L.map(mapEl, { scrollWheelZoom: false });

      L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      }).addTo(map);

      const bounds = L.latLngBounds([]);

      for (const park of tracker.parks) {
        const color = STATE_COLORS[park.state] ?? "#888";
        const marker = L.circleMarker([park.latitude, park.longitude], {
          radius: 5,
          color: "#172026",
          weight: 1,
          fillColor: color,
          fillOpacity: 0.85,
        }).addTo(map);

        bounds.extend([park.latitude, park.longitude]);
        marker.bindPopup(popupHtml(park));
      }

      if (bounds.isValid()) {
        map.fitBounds(bounds, { padding: [24, 24] });
      }
    }

    function escapeHtml(value: string) {
      return String(value).replace(/[&<>"']/g, (c: string) => {
        const e: Record<string, string> = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" };
        return e[c] ?? c;
      });
    }

    function popupHtml(park: { reference: string; name: string; stateName: string; activations: number; qsos: number }) {
      return `
        <strong>${escapeHtml(park.reference)}</strong>
        <span>${escapeHtml(park.name)}</span>
        <em>${escapeHtml(park.stateName)}</em>
        <span>${park.activations} activations · ${park.qsos} QSOs</span>
        <a href="https://pota.app/#/park/${escapeHtml(park.reference)}" target="_blank" rel="noreferrer">POTA page</a>
      `;
    }
  </script>
</BaseLayout>

<style>
  .rove-state-grid {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    max-width: 32rem;
  }

  .rove-state-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.4rem 0.5rem;
    border-radius: 4px;
    background: var(--color-surface-raised, #f5f0e8);
  }

  .rove-state-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1.5px solid #172026;
  }

  .rove-state-abbr {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    width: 2rem;
    flex-shrink: 0;
  }

  .rove-state-name {
    flex: 1;
    font-size: 0.9rem;
  }

  .rove-map-legend {
    flex-wrap: wrap;
  }

  .rove-constraint-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 0.75rem;
    margin: 0;
  }

  .rove-constraint-grid div {
    border-top: 1px solid var(--color-border, #ddd);
    padding-top: 0.5rem;
  }

  .rove-constraint-grid dt {
    color: var(--color-text-muted, #666);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .rove-constraint-grid dd {
    margin: 0.15rem 0 0;
    font-size: 0.95rem;
  }

  .rove-jurisdictions {
    color: var(--color-text-muted, #666);
    font-size: 0.9rem;
    margin: 1rem 0 0;
  }

  /* Itinerary */
  .rove-itinerary-empty {
    color: var(--color-text-muted, #666);
  }

  .rove-constraints {
    margin-bottom: 1.25rem;
  }

  .rove-day-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .rove-day {
    border: 1px solid var(--color-border, #ddd);
    border-radius: 6px;
    overflow: hidden;
  }

  .rove-day--violation {
    border-color: #c0392b;
  }

  .rove-day-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    background: var(--color-surface-raised, #f5f0e8);
    font-size: 0.8rem;
  }

  .rove-day-number {
    font-weight: 700;
    flex-shrink: 0;
  }

  .rove-day-date {
    flex: 1;
  }

  .rove-day-miles {
    color: var(--color-text-muted, #888);
    font-variant-numeric: tabular-nums;
  }

  .rove-day-states {
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-accent, #167246);
  }

  .rove-day-body {
    padding: 0.6rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .rove-overnight {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.9rem;
  }

  .rove-overnight-icon {
    font-size: 1rem;
    flex-shrink: 0;
  }

  .rove-overnight-name {
    font-weight: 600;
  }

  .rove-overnight-ref {
    font-size: 0.78rem;
    color: var(--color-text-muted, #888);
  }

  .rove-booking-status {
    font-size: 0.75rem;
    padding: 0.1em 0.45em;
    border-radius: 3px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .rove-booking-planned {
    background: #fff3cd;
    color: #856404;
  }

  .rove-booking-booked {
    background: #d1e7dd;
    color: #0a3622;
  }

  .rove-booking-n\/a {
    background: var(--color-surface-raised, #eee);
    color: var(--color-text-muted, #888);
  }

  .rove-camp-warning {
    font-size: 0.75rem;
    color: #c0392b;
    font-weight: 600;
  }

  .rove-park-targets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-size: 0.85rem;
  }

  .rove-park-targets li {
    display: flex;
    gap: 0.5rem;
  }

  .rove-day-notes {
    font-size: 0.85rem;
    color: var(--color-text-muted, #666);
    margin: 0;
  }

  .rove-state-count {
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted, #666);
  }
</style>
