---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const DEDICATED_PAGES = ["2026-activate-all-ri-pota", "2026-06-rove-to-fl"];
  const projects = (await getCollection("projects")).filter(
    (project) => !DEDICATED_PAGES.includes(project.id),
  );
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const formattedUpdated = project.data.updated.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
  timeZone: "UTC",
});
---

<BaseLayout title={`${project.data.title} / Projects / Robert Jackson`}>
  <article class="document">
    <header>
      <p class="eyebrow">Project</p>
      <h1>{project.data.title}</h1>
      <p class="meta">{project.data.status} · updated {formattedUpdated}</p>
      <p>{project.data.summary}</p>
      <div class="tags">
        {project.data.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </header>
    <Content />
  </article>
</BaseLayout>
