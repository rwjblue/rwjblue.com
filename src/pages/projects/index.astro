---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import riPotaTrackerData from "../../data/pota/ri-tracker.json";
import roveToFlData from "../../data/pota/rove-to-fl.json";
import { formatDate } from "../../lib/format";
import { effectiveProjectUpdatedDate } from "../../lib/project-updates";

const projects = (await getCollection("projects"))
  .map((project) => ({
    project,
    updated: effectiveProjectUpdatedDate(project, {
      riPotaTrackerData,
      roveToFlData,
    }),
  }))
  .sort((a, b) => b.updated.valueOf() - a.updated.valueOf());
---

<BaseLayout title="Projects / Robert Jackson">
  <section class="page-intro">
    <p class="eyebrow">Projects</p>
    <h1>Projects</h1>
    <p>
      Project context, ongoing work, historical threads, and experiments. This is
      closer to a workbench index than a portfolio.
    </p>
  </section>

  <div class="artifact-list full">
    {
      projects.map(({ project, updated }) => (
        <a href={`/projects/${project.id}/`} class="artifact-item">
          <span>
            {project.data.status} · updated {formatDate(updated)}
          </span>
          <strong>{project.data.title}</strong>
          <p>{project.data.summary}</p>
          <div class="tags">
            {project.data.tags.map((tag) => <em>{tag}</em>)}
          </div>
        </a>
      ))
    }
  </div>
</BaseLayout>
