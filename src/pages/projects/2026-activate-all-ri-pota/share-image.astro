---
import "leaflet/dist/leaflet.css";

import trackerData from "../../../data/pota/ri-tracker.json";

const trackerJson = JSON.stringify(trackerData);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1200" />
    <meta name="robots" content="noindex" />
    <style>
      :root {
        --bg: #f7f4ee;
        --panel: #fffdfa;
        --ink: #172026;
        --muted: #5f6f79;
        --quiet: #7a858c;
        --line: #d9ded8;
        --line-strong: #c5ccc4;
        --green: #2f6f4e;
        --rust: #8a4b2b;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        width: 1200px;
        height: 630px;
        overflow: hidden;
        background: var(--bg);
        color: var(--ink);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      .card {
        display: grid;
        grid-template-columns: 320px 1fr;
        height: 630px;
      }

      .card-left {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 40px 32px;
        border-right: 2px solid var(--ink);
        background: var(--panel);
      }

      .site-name {
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .card-title {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 6px;
        padding: 32px 0;
      }

      .eyebrow {
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--rust);
      }

      h1 {
        font-size: 2.1rem;
        font-weight: 800;
        line-height: 1.1;
        color: var(--ink);
      }

      .scoreboard {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border-top: 2px solid var(--ink);
      }

      .scoreboard-cell {
        padding: 14px 10px;
        border-bottom: 1px solid var(--line);
      }

      .scoreboard-cell + .scoreboard-cell {
        border-left: 1px solid var(--line);
      }

      .scoreboard-value {
        display: block;
        font-size: 1.6rem;
        font-weight: 800;
        line-height: 1;
        color: var(--ink);
      }

      .scoreboard-label {
        display: block;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
          monospace;
        font-size: 0.68rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--rust);
        margin-top: 4px;
      }

      .card-right {
        position: relative;
        overflow: hidden;
      }

      #share-map {
        width: 100%;
        height: 100%;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="card-left">
        <span class="site-name">rwjblue · N1RWJ</span>

        <div class="card-title">
          <p class="eyebrow">Project · POTA</p>
          <h1>2026 Activate All RI POTA</h1>
        </div>

        <div class="scoreboard">
          <div class="scoreboard-cell">
            <span class="scoreboard-value">{trackerData.summary.completed}</span>
            <span class="scoreboard-label">completed</span>
          </div>
          <div class="scoreboard-cell">
            <span class="scoreboard-value">{trackerData.summary.remaining}</span>
            <span class="scoreboard-label">remaining</span>
          </div>
          <div class="scoreboard-cell">
            <span class="scoreboard-value">{trackerData.summary.percentComplete}%</span>
            <span class="scoreboard-label">of {trackerData.summary.total}</span>
          </div>
        </div>
      </div>

      <div class="card-right">
        <div id="share-map"></div>
      </div>
    </div>

    <script type="application/json" id="share-tracker-data" set:html={trackerJson} />
    <script>
      import L from "leaflet";

      const dataEl = document.getElementById("share-tracker-data");
      const mapEl = document.getElementById("share-map");

      if (dataEl && mapEl) {
        const tracker = JSON.parse(dataEl.textContent ?? "{}");
        const map = L.map(mapEl, {
          scrollWheelZoom: false,
          zoomControl: false,
          attributionControl: false,
        });

        L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
          maxZoom: 19,
        }).addTo(map);

        const bounds = L.latLngBounds([]);
        const riBounds = L.latLngBounds([]);

        for (const ref of tracker.references) {
          const color = ref.status === "completed" ? "#167246" : "#ffeb2f";
          L.circleMarker([ref.latitude, ref.longitude], {
            radius: 9,
            color: "#172026",
            weight: 2,
            fillColor: color,
            fillOpacity: 0.96,
          }).addTo(map);

          bounds.extend([ref.latitude, ref.longitude]);
          if (
            ref.latitude >= 41.1 &&
            ref.latitude <= 42.1 &&
            ref.longitude >= -72.1 &&
            ref.longitude <= -71
          ) {
            riBounds.extend([ref.latitude, ref.longitude]);
          }
        }

        if (riBounds.isValid()) {
          map.fitBounds(riBounds, { padding: [32, 32], maxZoom: 10 });
        } else if (bounds.isValid()) {
          map.fitBounds(bounds, { padding: [24, 24] });
        } else {
          map.setView([41.58, -71.48], 9);
        }
      }
    </script>
  </body>
</html>
