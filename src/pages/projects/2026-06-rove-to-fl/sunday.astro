---
import "leaflet/dist/leaflet.css";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import dcRove from "../../../../data/pota/rove-to-fl/dc-rove.json";

interface OperatingStop {
  id: string;
  timing?: string;
  name: string;
  parking?: string;
  references: string[];
  uniqueAddsIfFirst?: string[];
  uniqueAddsAfterFort?: string[];
  uniqueAddsAfterFortAndLbj?: string[];
  uniqueAddsAfterFortLbjFdr?: string[];
  uniqueAddsAfterPrior?: string[];
  uniqueAddsAfterLbj?: string[];
}
interface TimelineAssumptions {
  activationMinutes: number;
  minimumActivationMinutes: number;
  sundayStartLocal: string;
  sundayStartUtc: string;
  notes: string;
}
interface TimelineStop {
  id: string;
  label?: string;
  directionsOriginId?: string;
  directionsDestinationId?: string;
  localStart: string;
  localEnd: string;
  utcStart: string;
  utcEnd: string;
  movementMode: "drive" | "walk" | "ride";
  movementFromPrior: string;
  movementMinutes: number;
  activationMinutes: number;
  cumulativeEntities: number;
  timelineNote: string;
}
interface OptionalTimelineAddOn {
  id: string;
  directionsOriginId: string;
  directionsDestinationId: string;
  placement: string;
  movementMode: "drive" | "walk" | "ride";
  movementMinutes: number;
  activationMinutes: number;
  entityAdds: number;
  timelineImpact: string;
  timelineNote: string;
}
interface MappedLeg {
  from: string;
  to: string;
  mode: string;
  distance: string;
  minutes: number;
  notes?: string;
}
interface RouteWaypoint {
  id: string;
  label: string;
  latitude: number;
  longitude: number;
  type: "activation" | "hotel" | "optional";
  notes: string;
}
interface ExpandedMallCandidate {
  reference: string;
  name: string;
  group: string;
  routeUse: string;
}
interface ExpandedMallInventory {
  summary: string;
  counts: Record<string, number>;
  candidateReferences: ExpandedMallCandidate[];
}
interface ExpandedMallRoute {
  name: string;
  strategy: string;
  countMilestones: { label: string; entities: number }[];
  caution: string;
}
interface RouteOptimizationStep {
  label: string;
  mode?: string;
  movement?: string;
  value?: string;
  finding?: string;
  minutesFromPrior?: number;
  cumulativeWalkMinutes?: number;
}
interface MapsEvidence {
  scenario: string;
  mode: string;
  distance: string;
  minutes: number;
  order?: string;
}
interface RouteOptimization {
  summary: string;
  constraints: string[];
  recommendedCoreOrder: RouteOptimizationStep[];
  expandedWalkOrder: RouteOptimizationStep[];
  addOnFindings: RouteOptimizationStep[];
  mapsEvidence: MapsEvidence[];
}

const operatingStops = dcRove.operatingStops as OperatingStop[];
const mappedLegs = dcRove.mappedLegs as MappedLeg[];
const timelineAssumptions = dcRove.timelineAssumptions as TimelineAssumptions;
const primaryTimeline = dcRove.primaryTimeline as TimelineStop[];
const optionalTimelineAddOns = dcRove.optionalTimelineAddOns as OptionalTimelineAddOn[];
const routeWaypoints = dcRove.routeWaypoints as RouteWaypoint[];
const expandedMallInventory = dcRove.expandedMallInventory as ExpandedMallInventory | undefined;
const expandedMallRoute = dcRove.expandedMallRoute as ExpandedMallRoute | undefined;
const routeOptimization = dcRove.routeOptimization as RouteOptimization | undefined;
const routeWaypointsJson = JSON.stringify(routeWaypoints);
const primaryRouteWaypointIds = [
  "co-canal-anglers",
  "foggy-bottom",
  "lbj-7fer",
  "jefferson",
  "fdr",
  "mlk",
  "korean",
  "lincoln",
  "vietnam",
  "constitution-gardens",
  "wwii",
  "washington-monument",
  "presidents-park",
  "wwi",
  "meadowood",
  "fredericksburg"
];
const primaryRouteJson = JSON.stringify(primaryRouteWaypointIds);

function formatMinutes(minutes: number) {
  if (minutes === 0) return "on site";
  const hours = Math.floor(minutes / 60);
  const mins = minutes % 60;
  return hours > 0 ? `${hours}h ${mins.toString().padStart(2, "0")}m` : `${mins}m`;
}

function potaUrl(reference: string) {
  return `https://pota.app/#/park/${reference}`;
}

function waypoint(id?: string) {
  return routeWaypoints.find((point) => point.id === id);
}

function coordinateLabel(point?: RouteWaypoint) {
  if (!point) return null;
  return `${point.latitude.toFixed(5)}, ${point.longitude.toFixed(5)} · ${maidenheadGrid(point.latitude, point.longitude)}`;
}

function appleMapsUrl(destination?: RouteWaypoint, origin?: RouteWaypoint, mode: "drive" | "walk" | "ride" = "drive") {
  if (!destination) return null;
  const params = new URLSearchParams();
  params.set("daddr", `${destination.latitude},${destination.longitude}`);
  params.set("q", destination.label);
  params.set("dirflg", mode === "walk" ? "w" : "d");
  if (origin) params.set("saddr", `${origin.latitude},${origin.longitude}`);
  return `https://maps.apple.com/?${params.toString()}`;
}

function directionsHref(timelineStop: TimelineStop) {
  return appleMapsUrl(
    waypoint(timelineStop.directionsDestinationId ?? timelineStop.id),
    waypoint(timelineStop.directionsOriginId),
    timelineStop.movementMode
  );
}

function waypointForTimeline(timelineStop: TimelineStop) {
  return waypoint(timelineStop.id) ?? waypoint(timelineStop.directionsDestinationId);
}

function maidenheadGrid(latitude: number, longitude: number) {
  let lon = longitude + 180;
  let lat = latitude + 90;
  const fieldLon = Math.floor(lon / 20);
  const fieldLat = Math.floor(lat / 10);
  lon -= fieldLon * 20;
  lat -= fieldLat * 10;
  const squareLon = Math.floor(lon / 2);
  const squareLat = Math.floor(lat);
  lon -= squareLon * 2;
  lat -= squareLat;
  const subsquareLon = Math.floor(lon * 12);
  const subsquareLat = Math.floor(lat * 24);
  return `${String.fromCharCode(65 + fieldLon)}${String.fromCharCode(65 + fieldLat)}${squareLon}${squareLat}${String.fromCharCode(97 + subsquareLon)}${String.fromCharCode(97 + subsquareLat)}`;
}

function uniqueAdds(stop: OperatingStop) {
  return (
    stop.uniqueAddsIfFirst ??
    stop.uniqueAddsAfterFort ??
    stop.uniqueAddsAfterFortAndLbj ??
    stop.uniqueAddsAfterFortLbjFdr ??
    stop.uniqueAddsAfterPrior ??
    stop.uniqueAddsAfterLbj ??
    []
  );
}

function stopFor(timelineStop: TimelineStop) {
  return operatingStops.find((stop) => stop.id === timelineStop.id);
}

function stopName(timelineStop: TimelineStop) {
  return timelineStop.label ?? stopFor(timelineStop)?.name ?? timelineStop.id;
}

function referencesFor(timelineStop: TimelineStop) {
  return stopFor(timelineStop)?.references ?? [];
}

function uniqueAddsFor(timelineStop: TimelineStop) {
  const stop = stopFor(timelineStop);
  return stop ? uniqueAdds(stop) : [];
}
---

<BaseLayout
  title="Sunday DC Rove / 2026 Rove to FL / N1RWJ"
  description="Detailed DC and NoVA Cheetah/Ostrich POTA rove plan for the 2026 Rhode Island to Florida trip."
  canonicalPath="/projects/2026-06-rove-to-fl/sunday/"
>
  <section class="pota-tracker-hero" aria-labelledby="page-title">
    <div>
      <p class="eyebrow">Project / POTA / Sunday</p>
      <h1 id="page-title">Sunday DC / NoVA rove</h1>
      <p class="lede strong">
        C&O Canal at Anglers opens the Sunday UTC day Saturday evening as the
        clean Maryland all-states anchor; LBJ and the expanded Mall sequence
        carry the Cheetah/Ostrich count, and Meadowood is the practical Virginia
        finish.
      </p>
      <p class="lede">
        This route is based on the CWops/W8WZ DC article, local POTA metadata,
        imported n-fer evidence, GeoJSON checks, and route estimates captured on
        June 15-20, 2026.
      </p>
    </div>

    <aside class="pota-tracker-panel rove-summary-panel">
      <nav class="rove-subnav" aria-label="Rove planning pages">
        <a href="/projects/2026-06-rove-to-fl/">Overview</a>
        <a href="/projects/2026-06-rove-to-fl/saturday/">Saturday rove</a>
        <a href="/projects/2026-06-rove-to-fl/sunday/">Sunday DC rove</a>
      </nav>
      <dl class="rove-summary-grid">
        <div>
          <dt>UTC day</dt>
          <dd>Starts Sat 20:00 EDT</dd>
        </div>
        <div>
          <dt>Planning pace</dt>
          <dd>{timelineAssumptions.activationMinutes} min stops</dd>
        </div>
        <div>
          <dt>Sunday start</dt>
          <dd>{timelineAssumptions.sundayStartLocal} / {timelineAssumptions.sundayStartUtc} UTC</dd>
        </div>
        <div>
          <dt>Target shape</dt>
          <dd>15 by Vietnam; 20 by WWI; VA at Meadowood</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="section-block wide" aria-labelledby="route-map-title">
    <div class="section-heading">
      <p class="section-label">Route map</p>
      <h2 id="route-map-title">DC operating map</h2>
    </div>

    <div id="dc-rove-map" class="rove-map" aria-label="Map of the Sunday DC rove operating stops"></div>
    <div class="rove-map-legend" aria-label="Map marker legend">
      <span><i style="background:#167246"></i>Activation</span>
      <span><i style="background:#1f6feb"></i>Hotel / anchor</span>
      <span><i style="background:#f28e2b"></i>Optional</span>
    </div>
  </section>

  <section class="section-block wide rove-timeline-section" aria-labelledby="timeline-title">
    <div class="section-heading">
      <p class="section-label">Estimated timeline</p>
      <h2 id="timeline-title">Primary Sunday UTC run</h2>
    </div>

    <p class="rove-note">
      {timelineAssumptions.notes} Local times are Eastern Daylight Time; UTC is
      shown because the rove award count follows the UTC day.
    </p>

    <ol class="rove-timeline-list">
      {primaryTimeline.map((timelineStop, index) => (
        <li>
          <div class="rove-time-block">
            <strong>{timelineStop.localStart}</strong>
            <span>{timelineStop.utcStart} UTC</span>
          </div>
          <article class={`rove-timeline-card ${timelineStop.activationMinutes === 0 ? "rove-timeline-card-arrival" : ""}`}>
            <div class="rove-card-topline">
              <span>{index === 0 ? "UTC opener" : timelineStop.activationMinutes === 0 ? "arrival" : `Stop ${index + 1}`}</span>
              <span>{timelineStop.movementMode} · {formatMinutes(timelineStop.movementMinutes)}</span>
            </div>
            <h3>{stopName(timelineStop)}</h3>
            {coordinateLabel(waypointForTimeline(timelineStop)) && (
              <p class="rove-coordinate-line">{coordinateLabel(waypointForTimeline(timelineStop))}</p>
            )}
            <dl class="rove-stop-meta">
              <div>
                <dt>Activate</dt>
                <dd>
                  {timelineStop.activationMinutes > 0
                    ? `${timelineStop.localStart}-${timelineStop.localEnd} local / ${timelineStop.utcStart}-${timelineStop.utcEnd} UTC`
                    : "no activation"}
                </dd>
              </div>
              <div>
                <dt>Move from prior</dt>
                <dd>{timelineStop.movementFromPrior}</dd>
              </div>
              <div>
                <dt>Running count</dt>
                <dd>{timelineStop.cumulativeEntities} entities</dd>
              </div>
            </dl>
            {directionsHref(timelineStop) && (
              <p class="rove-directions-link">
                <a href={directionsHref(timelineStop)} target="_blank" rel="noreferrer">
                  Directions
                </a>
              </p>
            )}
            <p>{timelineStop.timelineNote}</p>
            {referencesFor(timelineStop).length > 0 && (
              <p class="rove-reference-list">
                {referencesFor(timelineStop).map((reference) => (
                  <a href={potaUrl(reference)} target="_blank" rel="noreferrer">{reference}</a>
                ))}
              </p>
            )}
            {uniqueAddsFor(timelineStop).length > 0 && (
              <p class="rove-unique-adds">
                Unique here: {uniqueAddsFor(timelineStop).join(" / ")}
              </p>
            )}
          </article>
        </li>
      ))}
    </ol>
  </section>

  {routeOptimization && (
    <section class="section-block wide" aria-labelledby="route-optimization-title">
      <div class="section-heading">
        <p class="section-label">Google Maps optimization</p>
        <h2 id="route-optimization-title">Best order from Foggy Bottom</h2>
      </div>

      <p class="rove-note">{routeOptimization.summary}</p>

      <div class="rove-addon-grid rove-route-optimization-grid">
        <article>
          <div class="rove-card-topline">
            <span>recommended core</span>
            <span>value first</span>
          </div>
          <ol class="rove-ordered-compact-list">
            {routeOptimization.recommendedCoreOrder.map((step) => (
              <li>
                <strong>{step.label}</strong>
                {step.movement && <span>{step.movement}</span>}
                {step.value && <em>{step.value}</em>}
              </li>
            ))}
          </ol>
        </article>
        <article>
          <div class="rove-card-topline">
            <span>decision rules</span>
            <span>walk vs ride</span>
          </div>
          <ul class="rove-compact-list">
            {routeOptimization.addOnFindings.map((finding) => (
              <li><strong>{finding.label}:</strong> {finding.finding}</li>
            ))}
          </ul>
        </article>
      </div>

      <div class="rove-optimization-columns">
        <article>
          <h3>Expanded walk order</h3>
          <ol class="rove-walk-order-list">
            {routeOptimization.expandedWalkOrder.map((step) => (
              <li>
                <strong>{step.label}</strong>
                {typeof step.minutesFromPrior === "number" && (
                  <span>
                    +{step.minutesFromPrior}m / {step.cumulativeWalkMinutes}m total
                  </span>
                )}
              </li>
            ))}
          </ol>
        </article>
        <article>
          <h3>Mapped evidence</h3>
          <dl class="rove-evidence-list">
            {routeOptimization.mapsEvidence.map((evidence) => (
              <div>
                <dt>{evidence.scenario}</dt>
                <dd>{evidence.mode} · {evidence.distance} · {formatMinutes(evidence.minutes)}</dd>
                {evidence.order && <dd>{evidence.order}</dd>}
              </div>
            ))}
          </dl>
        </article>
      </div>
    </section>
  )}

  <section class="section-block wide" aria-labelledby="optional-title">
    <div class="section-heading">
      <p class="section-label">Stretch buffer</p>
      <h2 id="optional-title">Optional add-on</h2>
    </div>

    <div class="rove-addon-grid">
      {optionalTimelineAddOns.map((addOn) => {
        const stop = operatingStops.find((candidate) => candidate.id === addOn.id);
        return (
          <article>
            <div class="rove-card-topline">
              <span>{addOn.movementMode} detour</span>
              <span>{formatMinutes(addOn.movementMinutes)} movement</span>
            </div>
            <h3>{stop?.name ?? addOn.id}</h3>
            {coordinateLabel(waypoint(addOn.id)) && (
              <p class="rove-coordinate-line">{coordinateLabel(waypoint(addOn.id))}</p>
            )}
            <p>{addOn.placement}. {addOn.timelineImpact}</p>
            <p>{addOn.timelineNote}</p>
            <p class="rove-directions-link">
              <a
                href={appleMapsUrl(waypoint(addOn.directionsDestinationId), waypoint(addOn.directionsOriginId), addOn.movementMode)}
                target="_blank"
                rel="noreferrer"
              >
                Directions
              </a>
            </p>
            <p class="rove-reference-list">
              {(stop?.references ?? []).map((reference) => (
                <a href={potaUrl(reference)} target="_blank" rel="noreferrer">{reference}</a>
              ))}
            </p>
          </article>
        );
      })}
    </div>
  </section>

  {expandedMallInventory && expandedMallRoute && (
    <section class="section-block wide" aria-labelledby="expanded-mall-title">
      <div class="section-heading">
        <p class="section-label">Optimization inventory</p>
        <h2 id="expanded-mall-title">Expanded Mall and downtown list</h2>
      </div>

      <p class="rove-note">{expandedMallInventory.summary}</p>
      <p class="rove-note rove-important">{expandedMallRoute.caution}</p>

      <dl class="rove-summary-grid rove-count-grid">
        <div>
          <dt>DC cache</dt>
          <dd>{expandedMallInventory.counts.dcCacheReferences} refs</dd>
        </div>
        <div>
          <dt>Downtown max</dt>
          <dd>{expandedMallInventory.counts.downtownTotalWithFortAndLbj} entities</dd>
        </div>
        <div>
          <dt>With Dyke Marsh</dt>
          <dd>{expandedMallInventory.counts.downtownPlusDykeMarsh} entities</dd>
        </div>
        <div>
          <dt>With Mason Neck</dt>
          <dd>{expandedMallInventory.counts.downtownPlusDykeMarshAndMasonNeck} entities</dd>
        </div>
      </dl>

      <div class="rove-addon-grid">
        <article>
          <div class="rove-card-topline">
            <span>route shape</span>
            <span>aggressive</span>
          </div>
          <h3>{expandedMallRoute.name}</h3>
          <p>{expandedMallRoute.strategy}</p>
        </article>
        <article>
          <div class="rove-card-topline">
            <span>count milestones</span>
            <span>Sunday UTC</span>
          </div>
          <h3>Entity ladder</h3>
          <ul class="rove-compact-list">
            {expandedMallRoute.countMilestones.map((milestone) => (
              <li><strong>{milestone.entities}</strong> {milestone.label}</li>
            ))}
          </ul>
        </article>
      </div>

      <div class="rove-candidate-reference-grid">
        {expandedMallInventory.candidateReferences.map((candidate) => (
          <article>
            <div class="rove-card-topline">
              <span>{candidate.group}</span>
              <a href={potaUrl(candidate.reference)} target="_blank" rel="noreferrer">{candidate.reference}</a>
            </div>
            <h3>{candidate.name}</h3>
            <p>{candidate.routeUse}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="section-block wide" aria-labelledby="legs-title">
    <div class="section-heading">
      <p class="section-label">Movement</p>
      <h2 id="legs-title">Mapped movement legs</h2>
    </div>

    <div class="rove-leg-grid">
      {mappedLegs.map((leg) => (
        <article>
          <span>{leg.mode}</span>
          <strong>{leg.from} -> {leg.to}</strong>
          <dl>
            <div>
              <dt>Time</dt>
              <dd>{formatMinutes(leg.minutes)}</dd>
            </div>
            <div>
              <dt>Distance</dt>
              <dd>{leg.distance}</dd>
            </div>
          </dl>
          {leg.notes && <p>{leg.notes}</p>}
        </article>
      ))}
    </div>
  </section>

  <section class="section-block wide" aria-labelledby="verification-title">
    <div class="section-heading">
      <p class="section-label">Before relying on the count</p>
      <h2 id="verification-title">Open verification</h2>
    </div>

    <ul class="rove-check-list">
      {dcRove.openVerification.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="section-block wide" aria-labelledby="sources-title">
    <div class="section-heading">
      <p class="section-label">Source notes</p>
      <h2 id="sources-title">Activation spot evidence</h2>
    </div>

    <ul class="rove-check-list">
      <li>
        CWops/W8WZ gives the DC activation sequence and the low-profile
        bench/AX1 approach for the Mall stops. W3LAM corroborates the Lady Bird
        Johnson Park / Columbia Island Marina right-side parking-area 7-fer.
      </li>
      <li>
        The local n-fer export and outreach feedback provide evidence for the
        Greenbelt, LBJ, Mason Neck, Dyke Marsh, and Meadowood clusters. The
        selected late-night Maryland stop is now C&O Canal at Anglers because
        all-states credit is higher priority than Greenbelt's extra entity, and
        there is no Greenbelt campsite. Greenbelt remains a fallback only if
        legal access and the exact overlap position are defensible.
      </li>
      <li>
        NoVA local advice makes Meadowood's Mustang Equestrian Trailhead the
        practical Virginia finish; Mason Neck / Hartwell is the 2-fer stretch
        with more access, setup, and timing risk.
      </li>
      <li>
        Official NPS/FWS pages provide park access context; exact POTA trail
        overlap and antenna-rule compliance are tracked in the data file.
      </li>
    </ul>
  </section>

  <script type="application/json" id="dc-rove-waypoints" set:html={routeWaypointsJson} />
  <script type="application/json" id="dc-rove-primary-route" set:html={primaryRouteJson} />
  <script>
    import L from "leaflet";

    const mapEl = document.getElementById("dc-rove-map");
    const waypointsEl = document.getElementById("dc-rove-waypoints");
    const routeEl = document.getElementById("dc-rove-primary-route");

    if (mapEl && waypointsEl && routeEl) {
      const waypoints = JSON.parse(waypointsEl.textContent ?? "[]");
      const routeIds = JSON.parse(routeEl.textContent ?? "[]");
      const pointById = new Map(waypoints.map((point: { id: string }) => [point.id, point]));
      const routePoints = routeIds
        .map((id: string) => pointById.get(id))
        .filter(Boolean);
        const stopNumbers: Record<string, string> = {
        "co-canal-anglers": "M",
        "foggy-bottom": "H",
        "lbj-7fer": "1",
        jefferson: "2",
        fdr: "3",
        mlk: "4",
        korean: "5",
        lincoln: "6",
        vietnam: "7",
        "constitution-gardens": "8",
        wwii: "9",
        "washington-monument": "10",
        "presidents-park": "11",
        wwi: "12",
        meadowood: "VA",
      };
      const map = L.map(mapEl, { scrollWheelZoom: false });

      L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      }).addTo(map);

      const bounds = L.latLngBounds([]);
      const line = routePoints.map((point: { latitude: number; longitude: number }) => [
        point.latitude,
        point.longitude,
      ]);

      if (line.length > 1) {
        L.polyline(line, {
          color: "#167246",
          opacity: 0.8,
          weight: 3,
        }).addTo(map);
      }

      for (const point of routePoints) {
        const latLng: [number, number] = [point.latitude, point.longitude];
        bounds.extend(latLng);
        L.marker(latLng, {
          icon: L.divIcon({
            className: "rove-numbered-marker",
            html: `<span style="background:${waypointColor(point.type)}">${escapeHtml(stopNumbers[point.id] ?? "")}</span>`,
            iconSize: [26, 26],
            iconAnchor: [13, 13],
          }),
        })
          .bindPopup(waypointPopup(point))
          .addTo(map);
      }

      if (bounds.isValid()) map.fitBounds(bounds, { padding: [24, 24] });
    }

    function waypointColor(type: string) {
      if (type === "hotel") return "#1f6feb";
      if (type === "parking") return "#7f7f7f";
      if (type === "optional") return "#f28e2b";
      return "#167246";
    }

    function escapeHtml(value: string) {
      return String(value).replace(/[&<>"']/g, (c: string) => {
        const e: Record<string, string> = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" };
        return e[c] ?? c;
      });
    }

    function waypointPopup(point: {
      label: string;
      type: string;
      latitude: number;
      longitude: number;
    }) {
      return `
        <strong>${escapeHtml(point.label)}</strong>
        <em>${escapeHtml(point.type)} · ${point.latitude.toFixed(5)}, ${point.longitude.toFixed(5)}</em>
