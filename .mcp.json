{
  "mcpServers": {
    "pota": {
      "command": "pota-mcp"
    },
    "sota": {
      "command": "sota-mcp"
    },
    "solar": {
      "command": "solar-mcp"
    },
    "wspr": {
      "command": "wspr-mcp"
    },
    "qrz": {
      "command": "qrz-mcp"
    },
    "lotw": {
      "command": "lotw-mcp"
    },
    "google-maps": {
      "command": "npx",
      "args": [
        "-y",
        "@cablate/mcp-google-map",
        "--stdio"
      ],
      "env": {
        "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}"
      }
    }
  }
}
